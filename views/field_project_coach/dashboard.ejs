<%- include('../partials/header', { title: 'Dozent Transferprojekt-Dashboard - ThesisBuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Meine Diplomarbeiten (Dozent Transferprojekt)</h1>
    <div class="d-flex align-items-center gap-3">
        <a href="/api/transfer-project-overview.pdf" target="_blank" class="pill-btn" title="Gesamtübersicht aller Transferprojekt-Noten als PDF">
            <i class="bi bi-arrow-left-right"></i> Gesamtübersicht Transferprojekt
        </a>
        <span class="text-muted"><i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear %></span>
        <%- include('../partials/role-switcher', { availableRoles: availableRoles, currentRole: currentRole }) %>
    </div>
</div>

<% if (theses.length === 0) { %>
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        Im ausgewählten Diplomjahr sind Ihnen keine Diplomarbeiten zugewiesen.
    </div>
<% } else { %>
    <div class="row">
        <% theses.forEach(function(thesis) { %>
            <div class="col-md-6 mb-4">
                <div class="card h-100<% if (thesis.is_locked) { %> border-danger<% } %>">
                    <div class="card-header<% if (thesis.is_locked) { %> bg-warning-subtle<% } %>">
                        <h6 class="mb-0">
                            <% if (thesis.is_locked) { %><i class="bi bi-slash-circle-fill text-danger me-1" title="Diplomarbeit gesperrt"></i><% } %>
                            <i class="bi bi-file-text"></i> <%= thesis.title %>
                        </h6>
                    </div>
                    <div class="card-body">
                        <p><strong>Fachbereich:</strong> <%= thesis.department.name %></p>
                        <% if (thesis.sponsor) { %>
                            <p><strong>Auftraggeber:</strong> <%= thesis.sponsor %></p>
                        <% } %>
                        <div class="mt-3">
                            <h6>Studenten:</h6>
                            <% thesis.students.forEach(function(s) { %>
                                <div class="mb-2">
                                    <i class="bi bi-person-fill"></i> <%= s.name %>, <%= s.firstname %>
                                    <br><small class="text-muted"><%= s.email %></small>
                                </div>
                            <% }); %>
                        </div>
                        <% if (thesis.coaches.length > 0) { %>
                            <div class="mt-3">
                                <h6>Dozent/innen:</h6>
                                <% thesis.coaches.forEach(function(c) { %>
                                    <div class="mb-2">
                                        <i class="bi bi-person-badge"></i> <%= c.name %>, <%= c.firstname %>
                                        <br><small class="text-muted"><%= c.email %></small>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                    <div class="card-footer d-flex gap-2 flex-wrap">
                        <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                            <i class="bi bi-eye"></i> Details & Meilensteine
                        </a>
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                onclick="openEditTitleModal(<%= thesis.id %>, <%- JSON.stringify(thesis.title || '') %>)">
                            <i class="bi bi-pencil"></i> Titel bearbeiten
                        </button>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } %>

<!-- Modal: Titel bearbeiten -->
<div class="modal fade" id="editThesisTitleModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Titel der Diplomarbeit bearbeiten</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editThesisTitleForm">
                <div class="modal-body">
                    <input type="hidden" id="editThesisTitleId">
                    <div class="mb-3">
                        <label for="editThesisTitleInput" class="form-label">Titel</label>
                        <input type="text" class="form-control" id="editThesisTitleInput" minlength="5" maxlength="500" required>
                    </div>
                    <div id="editThesisTitleError" class="alert alert-danger d-none" role="alert"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function openEditTitleModal(thesisId, currentTitle) {
    document.getElementById('editThesisTitleId').value = thesisId;
    document.getElementById('editThesisTitleInput').value = currentTitle || '';
    document.getElementById('editThesisTitleError').classList.add('d-none');
    new bootstrap.Modal(document.getElementById('editThesisTitleModal')).show();
}

document.getElementById('editThesisTitleForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const errBox = document.getElementById('editThesisTitleError');
    errBox.classList.add('d-none');
    const id = document.getElementById('editThesisTitleId').value;
    const title = document.getElementById('editThesisTitleInput').value.trim();
    const res = await fetch(`/api/theses/${id}/title`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title }),
    });
    const d = await res.json().catch(() => ({}));
    if (d.success) {
        bootstrap.Modal.getInstance(document.getElementById('editThesisTitleModal')).hide();
        location.reload();
    } else {
        errBox.textContent = d.message || 'Speichern fehlgeschlagen';
        errBox.classList.remove('d-none');
    }
});
</script>

<%- include('../partials/footer') %>
