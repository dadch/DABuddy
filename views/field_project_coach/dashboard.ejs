<%- include('../partials/header', { title: 'Field Project Coach-Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Meine Diplomarbeiten (Field Project Coach)</h1>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear %>
    </div>
</div>

<% if (theses.length === 0) { %>
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        Im ausgewählten Diplomjahr sind Ihnen keine Diplomarbeiten zugewiesen.
    </div>
<% } else { %>
    <div class="row">
        <% theses.forEach(function(thesis) { %>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <h6 class="mb-0"><i class="bi bi-file-text"></i> <%= thesis.title %></h6>
                    </div>
                    <div class="card-body">
                        <p><strong>Fachbereich:</strong> <%= thesis.department.name %></p>
                        <% if (thesis.sponsor) { %>
                            <p><strong>Auftraggeber:</strong> <%= thesis.sponsor %></p>
                        <% } %>
                        <div class="mt-3">
                            <h6>Studenten:</h6>
                            <% thesis.students.forEach(function(s) { %>
                                <div class="mb-2">
                                    <i class="bi bi-person-fill"></i> <%= s.firstname %> <%= s.name %>
                                    <br><small class="text-muted"><%= s.email %></small>
                                </div>
                            <% }); %>
                        </div>
                        <% if (thesis.coaches.length > 0) { %>
                            <div class="mt-3">
                                <h6>Coaches:</h6>
                                <% thesis.coaches.forEach(function(c) { %>
                                    <div class="mb-2">
                                        <i class="bi bi-person-badge"></i> <%= c.firstname %> <%= c.name %>
                                        <br><small class="text-muted"><%= c.email %></small>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                    <div class="card-footer">
                        <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                            <i class="bi bi-eye"></i> Details & Meilensteine
                        </a>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } %>

<%- include('../partials/footer') %>
