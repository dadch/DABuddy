// ---------- Feedbackformular (Markdown-Editor via EasyMDE) ----------
let feedbackEditor = null; // EasyMDE-Instanz wird lazy beim ersten Öffnen erzeugt
function getFeedbackText() {
    return feedbackEditor ? feedbackEditor.value() : (document.getElementById('feedbackText').value || '');
}
function setFeedbackText(text) {
    if (feedbackEditor) feedbackEditor.value(text || '');
    else document.getElementById('feedbackText').value = text || '';
}
function ensureFeedbackEditor() {
    if (feedbackEditor || typeof EasyMDE === 'undefined') return;
    feedbackEditor = new EasyMDE({
        element: document.getElementById('feedbackText'),
        spellChecker: false,
        status: ['lines', 'words'],
        minHeight: '280px',
        toolbar: ['bold', 'italic', 'heading', '|', 'unordered-list', 'ordered-list', '|', 'preview', 'side-by-side', '|', 'guide'],
        previewRender: (plainText) => (window.marked ? marked.parse(plainText, { breaks: true, gfm: true }) : plainText),
    });
}

function setFeedbackError(msg) {
    const el = document.getElementById('feedbackError');
    if (!msg) { el.classList.add('d-none'); el.textContent = ''; }
    else { el.textContent = msg; el.classList.remove('d-none'); }
}
function openFeedbackModal(m) {
    document.getElementById('feedbackMilestoneId').value = m.id;
    document.getElementById('feedbackModalLabel').textContent = m.label || '';
    document.getElementById('feedbackInfo').innerHTML = '<small class="text-muted">Wird geladen…</small>';
    document.getElementById('feedbackPdfLink').classList.add('d-none');
    setFeedbackError('');

    // EasyMDE erst initialisieren wenn Modal sichtbar ist (sonst stimmt das Layout nicht).
    const modalEl = document.getElementById('feedbackModal');
    modalEl.addEventListener('shown.bs.modal', function onceShown() {
        modalEl.removeEventListener('shown.bs.modal', onceShown);
        ensureFeedbackEditor();
        // Inhalt nach erfolgreichem fetch nochmals setzen (falls schon geladen).
        if (modalEl.dataset.pendingFeedback != null) {
            setFeedbackText(modalEl.dataset.pendingFeedback);
            delete modalEl.dataset.pendingFeedback;
        }
    });

    fetch(`/api/thesis-milestones/${m.id}/feedback`)
        .then(r => r.json())
        .then(d => {
            if (!d.success) { setFeedbackError(d.message || 'Fehler beim Laden'); return; }
            // Wenn Editor schon vorhanden, direkt setzen; sonst auf shown.bs.modal warten.
            if (feedbackEditor) setFeedbackText(d.feedback_text || '');
            else modalEl.dataset.pendingFeedback = d.feedback_text || '';

            const groups = (d.group_grades || []).map(g =>
                `<span class="badge bg-secondary me-1">${escapeHtml(g.name)} ${g.grade != null ? g.grade.toFixed(1) : '—'}</span>`
            ).join('');
            const modN = d.module_grade != null ? d.module_grade.toFixed(1) : '—';
            document.getElementById('feedbackInfo').innerHTML =
                `${groups}<span class="badge bg-success">Modulnote ${modN}</span>` +
                (d.is_confidential ? ' <span class="badge bg-danger ms-2">Geheimhaltung – kein LLM</span>' : '');
            const genBtn = document.getElementById('feedbackGenBtn');
            genBtn.disabled = !d.has_final_evaluation || d.is_confidential;
            if (d.is_confidential) genBtn.title = 'Bei Geheimhaltung muss die Rückmeldung manuell verfasst werden';
            else if (!d.has_final_evaluation) genBtn.title = 'Voraussetzung: finale Bewertung';
            else genBtn.title = '';
            const link = document.getElementById('feedbackPdfLink');
            if (d.has_final_evaluation) {
                link.href = `/api/thesis-milestones/${m.id}/feedback.pdf`;
                link.classList.remove('d-none');
            }
        })
        .catch(err => { console.error(err); setFeedbackError('Netzwerkfehler'); });
    new bootstrap.Modal(modalEl).show();
}

function generateFeedback() {
    setFeedbackError('');
    const id = document.getElementById('feedbackMilestoneId').value;
    const current = getFeedbackText();
    if (current && current.trim().length > 0) {
        alert('Es ist bereits ein Text erfasst. Der bestehende Text wird beibehalten — keine erneute LLM-Aufbereitung.');
        return;
    }
    const btn = document.getElementById('feedbackGenBtn');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> wird vorbereitet…';
    fetch(`/api/thesis-milestones/${id}/feedback/generate`, { method: 'POST' })
        .then(r => r.json())
        .then(d => {
            if (!d.success) { setFeedbackError(d.message || 'Fehler bei der LLM-Aufbereitung'); return; }
            setFeedbackText(d.feedback_text || '');
        })
        .catch(err => { console.error(err); setFeedbackError('Netzwerkfehler bei der LLM-Anfrage'); })
        .finally(() => { btn.disabled = false; btn.innerHTML = orig; });
}

function saveFeedback() {
    setFeedbackError('');
    const id = document.getElementById('feedbackMilestoneId').value;
    const text = getFeedbackText();
    fetch(`/api/thesis-milestones/${id}/feedback`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ feedback_text: text }),
    })
    .then(r => r.json())
    .then(d => {
        if (!d.success) { setFeedbackError(d.message || 'Fehler beim Speichern'); return; }
    })
    .catch(err => { console.error(err); setFeedbackError('Netzwerkfehler beim Speichern'); });
}
</script>

