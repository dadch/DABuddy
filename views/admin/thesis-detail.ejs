<%- include('../partials/header', { title: 'Diplomarbeit-Details - ThesisBuddy', user: user }) %>

<%
const ROLE_LABELS = { student: 'Student', coach: 'Dozent/in', expert: 'ExpertIn', admin: 'Administrator', department_lead: 'FachbereichsleiterIn', field_project_coach: 'Dozent Transferprojekt' };
const ACTION_LABELS = { document_upload: 'Dokument hochgeladen', document_update: 'Dokument aktualisiert', document_delete: 'Dokument gelöscht', evaluation_create: 'Bewertung erfasst', evaluation_update: 'Bewertung aktualisiert', milestone_approved: 'Dokument-Freigabe erteilt', milestone_revoked: 'Dokument-Freigabe zurückgezogen', milestone_released: 'Meilenstein freigegeben (gestartet)', milestone_locked: 'Meilenstein gesperrt' };
const isAdmin = user.role === 'admin';
const fmtDateTime = (d) => new Date(d).toLocaleDateString('de-CH') + ' ' + new Date(d).toLocaleTimeString('de-CH', { hour: '2-digit', minute: '2-digit' });
%>

<% const hasTransferProject = (milestones || []).some(m => m.is_transfer_project); %>
<% const isThesisDeptLead = user.role === 'department_lead' && thesis.department && thesis.department.department_lead_id === user.id; %>
<% const canEditDueAt = isAdmin || isThesisDeptLead; %>
<%- include('../partials/thesis-page-header', { thesis: thesis, user: user, hasTransferProject: hasTransferProject }) %>

<div class="row">
    <div class="col-lg-12">
        <%- include('../partials/thesis-info-card', { thesis: thesis, user: user }) %>
        <%- include('../partials/confidentiality-section', { thesis: thesis, user: user }) %>
        <%- include('../partials/thesis-lock-section', { thesis: thesis, user: user }) %>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-flag"></i> Meilensteine</h5>
            </div>
            <div class="card-body">
                <% if (milestones.length === 0) { %>
                    <div class="text-center py-4">
                        <i class="bi bi-flag text-muted" style="font-size: 48px;"></i>
                        <p class="text-muted mt-2">Keine Meilensteine für diese Diplomarbeit.</p>
                    </div>
                <% } else { %>
                    <% milestones.forEach(function(m) { %>
                        <%
                        const docs = (m.documents || []).slice().sort((a, b) => b.version - a.version);
                        const hasDocs = docs.length > 0;
                        const currentDoc = docs.find(d => d.is_current) || (hasDocs ? docs[0] : null);
                        const isResponsible = (user.role === m.responsible_role) || isAdmin;
                        const isCoachOfThesis = (thesis.coaches || []).some(c => c.id === user.id);
                        const canRelease = isAdmin || (user.role === 'coach' && isCoachOfThesis);
                        const cats = (m.uploadCategories || []).slice().sort((a, b) => (a.label||'').localeCompare(b.label||''));
                        const hasCats = cats.length > 0;
                        const showUpload = !hasCats && m.allow_upload && isResponsible && (!hasDocs || m.allow_update) && (m.released || isAdmin);
                        const canEvaluate = m.requires_evaluation && (user.role === m.evaluator_role || isAdmin);
                        const evalByKind = {};
                        (m.thesisEvaluations || []).forEach(e => { evalByKind[e.kind] = e; });
                        const finalExists = !!evalByKind['final'];
                        const isEvaluator1 = (user.role === m.evaluator_role) || isAdmin;
                        const isEvaluator2 = (user.role === m.evaluator_role_2) || isAdmin;
                        const canFeedback = m.feedback_form_enabled && (isAdmin || user.role === m.evaluator_role || (m.double_evaluation && user.role === m.evaluator_role_2));
                        const feedbackFinal = m.double_evaluation ? evalByKind['final'] : evalByKind['single'];
                        const approvalSlots = [];
                        if (m.requires_approval) approvalSlots.push({ n: 1, role: m.approver_role, approvedAt: m.approved_at, approver: m.approver });
                        if (m.requires_approval_2) approvalSlots.push({ n: 2, role: m.approver_role_2, approvedAt: m.approved_at_2, approver: m.approver2 });
                        const allApproved = approvalSlots.length > 0 && approvalSlots.every(s => s.approvedAt);
                        const overdue = !hasDocs && new Date(m.due_at) < new Date();
                        %>
                        <div class="milestone-card mb-3">
                            <div class="d-flex justify-content-between align-items-start flex-wrap">
                                <div>
                                    <h6 class="mb-1"><%= m.label %></h6>
                                    <div class="small">
                                        <span class="<%= overdue ? 'text-danger fw-bold' : 'text-muted' %>">
                                            <i class="bi bi-calendar-event"></i> <%= fmtDateTime(m.due_at) %>
                                            <% if (overdue) { %> (überfällig)<% } %>
                                        </span>
                                        <% if (m.due_at_overridden) { %>
                                            <span class="badge bg-info" title="Termin wurde für diese Diplomarbeit individuell gesetzt">
                                                <i class="bi bi-clock-history"></i> Individuell
                                            </span>
                                        <% } %>
                                        <% if (canEditDueAt) { %>
                                            <button class="btn btn-sm btn-link p-0 ms-1" onclick='openOverrideDueAt(<%- JSON.stringify({ id: m.id, label: m.label, due_at: m.due_at }) %>)' title="Termin pro Diplomarbeit übersteuern">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <% if (m.due_at_overridden) { %>
                                                <button class="btn btn-sm btn-link p-0 ms-1" onclick="resetDueAt(<%= m.id %>, '<%= m.label.replace(/'/g, "\\'") %>')" title="Auf Vorlagen-Termin zurücksetzen">
                                                    <i class="bi bi-arrow-counterclockwise"></i>
                                                </button>
                                            <% } %>
                                        <% } %>
                                        <span class="badge bg-secondary ms-2">Verantwortlich: <%= ROLE_LABELS[m.responsible_role] || m.responsible_role %></span>
                                        <% if (m.released) { %>
                                            <span class="badge bg-success"><i class="bi bi-unlock"></i> Freigegeben</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary"><i class="bi bi-lock"></i> Gesperrt</span>
                                        <% } %>
                                        <% if (m.requires_evaluation) { %>
                                            <span class="badge bg-warning text-dark">Bewertung: <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %></span>
                                        <% } %>
                                        <% if (m.is_transfer_project) { %>
                                            <span class="badge bg-info"><i class="bi bi-arrow-left-right"></i> Transferprojekt</span>
                                        <% } %>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <% if (canRelease) { %>
                                        <% if (!m.released) { %>
                                            <button class="btn btn-success btn-sm" onclick="setMilestoneReleased(<%= m.id %>, true)"><i class="bi bi-unlock"></i> Freigeben</button>
                                        <% } else { %>
                                            <button class="btn btn-outline-secondary btn-sm" onclick="setMilestoneReleased(<%= m.id %>, false)"><i class="bi bi-lock"></i> Sperren</button>
                                        <% } %>
                                    <% } %>
                                    <% if (showUpload) { %>
                                        <button class="btn btn-outline-primary btn-sm" onclick="openUploadModal(<%= m.id %>, '<%= m.label.replace(/'/g, "\\'") %>')">
                                            <i class="bi bi-upload"></i> <%= hasDocs ? 'Aktualisieren' : 'Hochladen' %>
                                        </button>
                                    <% } else if (!m.released) { %>
                                        <span class="text-muted small">Noch nicht freigegeben</span>
                                    <% } else if (!m.allow_upload) { %>
                                        <span class="text-muted small">Kein Upload vorgesehen</span>
                                    <% } else if (!hasDocs) { %>
                                        <span class="text-muted small">Wartet auf <%= ROLE_LABELS[m.responsible_role] || m.responsible_role %></span>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Dokumente -->
                            <%
                            // Hilfsfunktion: Render eines Dokumenten-Eintrags.
                            function renderDocRow(doc) { %>
                                <div class="d-flex justify-content-between align-items-center border-top py-2">
                                    <div>
                                        <a href="/api/thesis-milestone-documents/<%= doc.id %>/download" class="text-decoration-none">
                                            <i class="bi bi-file-earmark-pdf text-danger"></i> <%= doc.file_name %>
                                        </a>
                                        <% if (doc.is_current) { %>
                                            <span class="badge bg-success ms-1">Aktuell · v<%= doc.version %></span>
                                        <% } else { %>
                                            <span class="badge bg-secondary ms-1">Frühere Version · v<%= doc.version %></span>
                                        <% } %>
                                        <br>
                                        <small class="text-muted">
                                            <%= formatFileSize(doc.file_size) %> · hochgeladen von
                                            <%= doc.uploader ? (doc.uploader.name + ', ' + doc.uploader.firstname) : 'unbekannt' %>
                                            am <%= fmtDateTime(doc.uploaded_at) %>
                                            <% if (!doc.is_current && doc.superseded_at) { %>
                                                · ersetzt am <%= fmtDateTime(doc.superseded_at) %>
                                            <% } %>
                                        </small>
                                    </div>
                                    <% if (isAdmin) { %>
                                        <button class="btn btn-outline-danger btn-sm" onclick="deleteDocument(<%= doc.id %>)" title="Dokumentversion löschen (Admin)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    <% } %>
                                </div>
                            <% } %>

                            <% if (!hasCats) { /* Legacy: ein Slot ohne Kategorie */ %>
                                <% if (hasDocs) { %>
                                    <div class="mt-3">
                                        <% docs.forEach(function(doc) { renderDocRow(doc); }); %>
                                    </div>
                                <% } else { %>
                                    <div class="mt-2"><small class="text-muted"><i class="bi bi-dash-circle"></i> Noch kein Dokument hochgeladen.</small></div>
                                <% } %>
                            <% } else { /* Pro Upload-Kategorie ein eigener Slot */ %>
                                <div class="mt-3">
                                    <% cats.forEach(function(cat) {
                                        const catDocs = docs.filter(d => d.upload_category_id === cat.id);
                                        const catHasDocs = catDocs.length > 0;
                                        const catShowUpload = m.allow_upload && isResponsible && (!catHasDocs || m.allow_update) && (m.released || isAdmin);
                                    %>
                                        <div class="rounded border mb-2 p-2">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <strong><i class="bi bi-tag"></i> <%= cat.label %></strong>
                                                </div>
                                                <div>
                                                    <% if (catShowUpload) { %>
                                                        <button class="btn btn-outline-primary btn-sm"
                                                                onclick="openUploadModal(<%= m.id %>, '<%= m.label.replace(/'/g, "\\'") %>', <%= cat.id %>, '<%= cat.label.replace(/'/g, "\\'") %>')">
                                                            <i class="bi bi-upload"></i> <%= catHasDocs ? 'Aktualisieren' : 'Hochladen' %>
                                                        </button>
                                                    <% } else if (!m.released) { %>
                                                        <span class="text-muted small">Noch nicht freigegeben</span>
                                                    <% } else if (!m.allow_upload) { %>
                                                        <span class="text-muted small">Kein Upload</span>
                                                    <% } else if (!catHasDocs) { %>
                                                        <span class="text-muted small">Wartet auf <%= ROLE_LABELS[m.responsible_role] || m.responsible_role %></span>
                                                    <% } %>
                                                </div>
                                            </div>
                                            <% if (catHasDocs) { catDocs.forEach(function(doc) { renderDocRow(doc); }); } else { %>
                                                <small class="text-muted d-block mt-1"><i class="bi bi-dash-circle"></i> Noch kein Dokument hochgeladen.</small>
                                            <% } %>
                                        </div>
                                    <% }); %>
                                    <%
                                    const orphans = docs.filter(d => !cats.find(c => c.id === d.upload_category_id));
                                    if (orphans.length > 0) { %>
                                        <div class="rounded border mb-2 p-2">
                                            <strong class="small text-muted"><i class="bi bi-archive"></i> Weitere Dokumente</strong>
                                            <% orphans.forEach(function(doc) { renderDocRow(doc); }); %>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Bewertung -->
                            <% if (m.requires_evaluation && m.double_evaluation) { %>
                                <%
                                const phases = [
                                    { kind: 'first', title: 'Bewertung 1', role: m.evaluator_role, owner: isEvaluator1, ev: evalByKind['first'], canView: isAdmin || isEvaluator1 || finalExists },
                                    { kind: 'second', title: 'Bewertung 2', role: m.evaluator_role_2, owner: isEvaluator2, ev: evalByKind['second'], canView: isAdmin || isEvaluator2 || finalExists },
                                    { kind: 'final', title: 'Finale Bewertung', role: null, owner: (isEvaluator1 || isEvaluator2), ev: evalByKind['final'], canView: true },
                                ];
                                %>
                                <div class="mt-3 bg-light rounded p-2">
                                    <strong class="small"><i class="bi bi-people"></i> Doppelbewertung</strong>
                                    <span class="text-muted small">· <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %> + <%= ROLE_LABELS[m.evaluator_role_2] || m.evaluator_role_2 %></span>
                                    <% phases.forEach(function(p) { %>
                                        <div class="d-flex justify-content-between align-items-center py-1 small border-top">
                                            <div>
                                                <strong><%= p.title %></strong>
                                                <% if (p.role) { %><span class="text-muted">· <%= ROLE_LABELS[p.role] || p.role %></span><% } %>
                                                <% if (p.ev && p.canView && p.ev.overall_grade != null) { %>
                                                    <span class="badge bg-success">Note <%= Number(p.ev.overall_grade).toFixed(1) %></span>
                                                    <% if (!p.ev.completed) { %><span class="text-muted">(in Bearbeitung)</span><% } %>
                                                <% } else if (p.ev) { %>
                                                    <% if (p.canView) { %><span class="badge bg-warning text-dark">in Bearbeitung</span><% } else { %><span class="text-muted">verdeckt bis finale Bewertung</span><% } %>
                                                <% } else { %>
                                                    <span class="text-muted">noch nicht erstellt</span>
                                                <% } %>
                                            </div>
                                            <div>
                                                <% if (p.owner) { %>
                                                    <button class="btn btn-outline-secondary btn-sm" onclick="openEvaluationForm(<%= m.id %>, '<%= p.kind %>', true)"><i class="bi bi-clipboard-check"></i> ausfüllen</button>
                                                <% } else if (p.canView && p.ev) { %>
                                                    <button class="btn btn-outline-secondary btn-sm" onclick="openEvaluationForm(<%= m.id %>, '<%= p.kind %>', false)"><i class="bi bi-eye"></i> ansehen</button>
                                                <% } %>
                                                <% if (p.ev && p.canView) { %>
                                                    <a class="btn btn-outline-danger btn-sm" href="/api/thesis-milestones/<%= m.id %>/evaluation.pdf?kind=<%= p.kind %>" target="_blank" title="Als PDF"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } else if (m.requires_evaluation) { %>
                                <% const single = evalByKind['single']; %>
                                <div class="mt-3 bg-light rounded p-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="small">
                                            <i class="bi bi-star"></i> Bewertung
                                            <% if (m.evaluation_form_id) { %><span class="badge bg-primary ms-1">Formular</span><% } %>
                                            <span class="text-muted">· <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %></span>
                                        </strong>
                                        <span>
                                        <% if (m.evaluation_form_id) { %>
                                            <button class="btn btn-outline-secondary btn-sm" onclick="openEvaluationForm(<%= m.id %>, 'single', <%= canEvaluate ? 'true' : 'false' %>)">
                                                <i class="bi bi-clipboard-check"></i> Bewertung <%= canEvaluate ? 'ausfüllen' : 'ansehen' %>
                                            </button>
                                            <% if (single) { %>
                                                <a class="btn btn-outline-danger btn-sm" href="/api/thesis-milestones/<%= m.id %>/evaluation.pdf?kind=single" target="_blank" title="Als PDF"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                                            <% } %>
                                        <% } else { %>
                                            <% if (canEvaluate) { %>
                                                <button class="btn btn-outline-secondary btn-sm" onclick='openEvalModal(<%- JSON.stringify({ id: m.id, label: m.label, evaluation: m.evaluation || "" }) %>)'>
                                                    <i class="bi bi-pencil"></i> <%= m.evaluation ? 'Bewertung bearbeiten' : 'Bewerten' %>
                                                </button>
                                            <% } %>
                                            <% if (m.evaluation) { %>
                                                <a class="btn btn-outline-danger btn-sm" href="/api/thesis-milestones/<%= m.id %>/evaluation.pdf" target="_blank" title="Als PDF"><i class="bi bi-file-earmark-pdf"></i> PDF</a>
                                            <% } %>
                                        <% } %>
                                        </span>
                                    </div>
                                    <% if (m.evaluation_form_id) { %>
                                        <% if (single && single.overall_grade != null) { %>
                                            <div class="mt-2">
                                                Gesamtnote: <strong><%= Number(single.overall_grade).toFixed(1) %></strong>
                                                <% (single.groups || []).forEach(function(g) { %>
                                                    <% if (g.grade != null) { %>
                                                        <span class="badge bg-secondary ms-1" title="<%= g.name %>"><%= g.name %>: <%= Number(g.grade).toFixed(1) %></span>
                                                    <% } %>
                                                <% }); %>
                                                <br><small class="text-muted">
                                                    <%= single.completed ? 'Abgeschlossen' : 'In Bearbeitung' %>
                                                    <% if (single.evaluator) { %> · von <%= single.evaluator.name %>, <%= single.evaluator.firstname %><% } %>
                                                    <% if (single.evaluated_at) { %> am <%= fmtDateTime(single.evaluated_at) %><% } %>
                                                </small>
                                            </div>
                                        <% } else { %>
                                            <div class="mt-1"><small class="text-muted">Noch keine Bewertung erfasst.</small></div>
                                        <% } %>
                                    <% } else { %>
                                        <% if (m.evaluation) { %>
                                            <div class="mt-2" style="white-space: pre-wrap;"><%= m.evaluation %></div>
                                            <small class="text-muted">
                                                <%= m.evaluator ? ('von ' + m.evaluator.name + ', ' + m.evaluator.firstname) : '' %>
                                                <% if (m.evaluated_at) { %> am <%= fmtDateTime(m.evaluated_at) %><% } %>
                                            </small>
                                        <% } else { %>
                                            <div class="mt-1"><small class="text-muted">Noch keine Bewertung erfasst.</small></div>
                                        <% } %>
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Feedbackformular -->
                            <% if (m.feedback_form_enabled && canFeedback) { %>
                                <div class="mt-3 border rounded p-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="small"><i class="bi bi-chat-square-text"></i> Feedbackformular</strong>
                                        <% if (feedbackFinal) { %>
                                            <button class="btn btn-outline-secondary btn-sm" onclick='openFeedbackModal(<%- JSON.stringify({ id: m.id, label: m.label }) %>)'>
                                                <i class="bi bi-pencil"></i> Rückmeldung bearbeiten
                                            </button>
                                        <% } else { %>
                                            <span class="text-muted small">Eine finale Bewertung ist Voraussetzung.</span>
                                        <% } %>
                                    </div>
                                    <% if (m.feedback_text) { %>
                                        <div class="mt-1"><small class="text-muted"><i class="bi bi-check"></i> Rückmeldung erfasst</small></div>
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Freigaben -->
                            <% if (approvalSlots.length > 0) { %>
                                <div class="mt-3 border rounded p-2 <%= allApproved ? 'border-success' : '' %>">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <strong class="small"><i class="bi bi-unlock"></i> Freigaben</strong>
                                        <% if (allApproved) { %><span class="badge bg-success"><i class="bi bi-check-circle"></i> Vollständig freigegeben</span><% } %>
                                    </div>
                                    <% approvalSlots.forEach(function(s) { %>
                                        <% const canApproveSlot = (user.role === s.role) || isAdmin; %>
                                        <div class="d-flex justify-content-between align-items-center py-1 small">
                                            <div>
                                                <strong>Freigabe <%= s.n %></strong>
                                                <span class="text-muted">· <%= ROLE_LABELS[s.role] || s.role %></span>
                                                <% if (s.approvedAt) { %>
                                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Freigegeben</span>
                                                    <span class="text-muted">
                                                        <% if (s.approver) { %>von <%= s.approver.name %>, <%= s.approver.firstname %><% } %>
                                                        am <%= fmtDateTime(s.approvedAt) %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark">offen</span>
                                                <% } %>
                                            </div>
                                            <% if (canApproveSlot) { %>
                                                <div>
                                                    <% if (!s.approvedAt) { %>
                                                        <button class="btn btn-success btn-sm" onclick="setApproval(<%= m.id %>, <%= s.n %>, true)"><i class="bi bi-check-lg"></i> Freigeben</button>
                                                    <% } else { %>
                                                        <button class="btn btn-outline-danger btn-sm" onclick="setApproval(<%= m.id %>, <%= s.n %>, false)"><i class="bi bi-x-lg"></i> Zurückziehen</button>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>

        <!-- Änderungsprotokoll -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Änderungsprotokoll</h5>
            </div>
            <div class="card-body">
                <% if (!logs || logs.length === 0) { %>
                    <p class="text-muted mb-0">Noch keine Änderungen protokolliert.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Zeitstempel</th>
                                    <th>Benutzer</th>
                                    <th>Aktion</th>
                                    <th>Detail</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% logs.forEach(function(log) { %>
                                    <tr>
                                        <td class="text-nowrap"><small><%= fmtDateTime(log.createdAt) %></small></td>
                                        <td><small><%= log.user ? (log.user.name + ', ' + log.user.firstname) : 'unbekannt' %></small></td>
                                        <td><small><%= ACTION_LABELS[log.action] || log.action %></small></td>
                                        <td><small class="text-muted"><%= log.detail || '' %></small></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dokument hochladen — <span id="uploadModalLabel"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="uploadForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <input type="hidden" id="uploadMilestoneId">
                    <input type="hidden" id="uploadCategoryId" name="upload_category_id">
                    <div id="uploadCategoryRow" class="mb-3 d-none">
                        <label class="form-label">Upload-Kategorie</label>
                        <input type="text" class="form-control" id="uploadCategoryLabel" disabled>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">PDF-Datei</label>
                        <input type="file" class="form-control" name="document" accept=".pdf" required>
                        <div class="form-text">Maximale Dateigrösse: 50 MB. Nur PDF-Dateien. Frühere Versionen bleiben erhalten.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Hochladen</button>
                </div>
            </form>
        </div>
    </div>
