                    </div>
                    <div class="mb-3 d-none" id="editApproverWrap">
                        <label class="form-label">Freigebende Rolle (Freigabe 1)</label>
                        <select class="form-select" name="approver_role" id="editApproverRole">
                            <option value="">Rolle auswählen...</option>
