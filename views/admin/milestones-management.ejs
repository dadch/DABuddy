                        </select>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="requires_approval_2" id="editRequiresApproval2" onchange="toggleApprover2('edit')">
                        <label class="form-check-label" for="editRequiresApproval2">Freigabe 2 erforderlich</label>
                    </div>
                    <div class="mb-3 d-none" id="editApprover2Wrap">
                        <label class="form-label">Freigebende Rolle (Freigabe 2)</label>
                        <select class="form-select" name="approver_role_2" id="editApproverRole2">
                            <option value="">Rolle auswählen...</option>
                            <option value="student">Student</option>
                            <option value="coach">Dozent/in</option>
                            <option value="expert">ExpertIn</option>
                            <option value="department_lead">FachbereichsleiterIn</option>
                            <option value="field_project_coach">Dozent Transferprojekt</option>
                            <option value="admin">Administrator</option>
                        </select>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="is_transfer_project" id="editIsTransferProject">
                        <label class="form-check-label" for="editIsTransferProject">Transferprojekt</label>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="feedback_form_enabled" id="editFeedbackFormEnabled">
                        <label class="form-check-label" for="editFeedbackFormEnabled">Feedbackformular aktivieren (Voraussetzung: finale Bewertung)</label>
                    </div>
                    <div class="mb-3">
                        <label for="editUploadCategories" class="form-label">Upload-Kategorien</label>
                        <select class="form-select" id="editUploadCategories" name="upload_categories" multiple size="4">
                            <% (uploadCategories || []).forEach(function(c) { %>
                                <option value="<%= c.id %>"><%= categoryLabel(c) %><%= c.is_active ? '' : ' (deaktiviert)' %></option>
                            <% }); %>
                        </select>
                        <div class="form-text">Snapshots existierender DAs werden beim „Anwenden auf existierende" nur ergänzt, nie reduziert.</div>
                    </div>
                    <hr>
                    <h6 class="mb-2"><i class="bi bi-envelope-paper"></i> Mail-Erinnerungen</h6>
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <label class="form-label small">Beginn Erinnerungen ab</label>
                            <input type="datetime-local" class="form-control" name="reminder_start_at" id="editReminderStartAt">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Periodizität (Tage)</label>
                            <input type="number" class="form-control" name="reminder_period_days" id="editReminderPeriodDays" min="1" step="1">
                            <div class="form-text">Ab 3 Tagen vor Termin täglich (fix).</div>
                        </div>
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <label class="form-label small">Termin Bewertung (Einzel)</label>
                            <input type="datetime-local" class="form-control" name="single_due_at" id="editSingleDueAt">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Termin Bewertung 1</label>
                            <input type="datetime-local" class="form-control" name="first_due_at" id="editFirstDueAt">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Termin Bewertung 2</label>
                            <input type="datetime-local" class="form-control" name="second_due_at" id="editSecondDueAt">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Termin finale Bewertung</label>
                            <input type="datetime-local" class="form-control" name="final_due_at" id="editFinalDueAt">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Termin Feedbackformular</label>
                            <input type="datetime-local" class="form-control" name="feedback_due_at" id="editFeedbackDueAt">
                        </div>
                    </div>
                    <div class="form-text mb-3">
                        Alle Bewertungs- und Feedbacktermine müssen nach dem Meilenstein-Termin liegen.
                    </div>
                    <hr>
                    <% if (thesesCount > 0) { %>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="applyToExisting" id="editApplyToExisting">
                        <label class="form-check-label" for="editApplyToExisting">
                            Änderung auf bereits existierende Diplomarbeiten anwenden (<%= thesesCount %>)
                        </label>
                    </div>
                    <div class="form-check ms-4">
                        <input type="checkbox" class="form-check-input" name="overrideAll" id="editOverrideAll">
                        <label class="form-check-label" for="editOverrideAll">
                            Auch individuell überschriebene Termine ersetzen
                            <span class="text-muted small">(sonst bleiben Overrides erhalten)</span>
                        </label>
                    </div>
                    <% } %>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Löschen Modal -->
<div class="modal fade" id="deleteMilestoneModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Meilenstein löschen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="deleteMilestoneForm">
                <div class="modal-body">
                    <input type="hidden" id="deleteMilestoneId">
                    <p>Möchten Sie den Meilenstein <strong id="deleteMilestoneLabel"></strong> wirklich löschen?</p>
                    <p class="text-muted">
                        Diese Aktion entfernt den Meilenstein aus der Vorlage. Bereits zugewiesene Instanzen pro Diplomarbeit werden je nach Auswahl behandelt.
                    </p>
                    <div class="form-check">
                        <input type="radio" class="form-check-input" name="keepUploaded" id="keepUploadedYes" value="true" checked>
                        <label class="form-check-label" for="keepUploadedYes">
                            Bereits hochgeladene Dokumente behalten<br>
                            <small class="text-muted">Diplomarbeiten mit hochgeladenem Dokument für diesen Meilenstein bleiben unverändert. Andere werden gelöscht.</small>
                        </label>
                    </div>
                    <div class="form-check mt-2">
                        <input type="radio" class="form-check-input" name="keepUploaded" id="keepUploadedNo" value="false">
                        <label class="form-check-label" for="keepUploadedNo">
                            Alle löschen<br>
                            <small class="text-muted">Auch bereits hochgeladene Dokumente werden entfernt.</small>
                        </label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-danger">Löschen</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
const selectedYearId = <%= selectedYear.id %>;

function roleLabel(role) {
    const m = { student: 'Student', coach: 'Dozent/in', expert: 'ExpertIn', admin: 'Administrator', department_lead: 'FachbereichsleiterIn' };
    return m[role] || role;
}

function toLocalInput(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const pad = n => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

let evaluationForms = [];

function loadEvaluationForms() {
    return fetch('/api/evaluation-forms').then(r => r.json()).then(forms => {
        evaluationForms = forms;
        ['addEvalForm', 'editEvalForm'].forEach(selId => {
            const sel = document.getElementById(selId);
            const current = sel.value;
            sel.innerHTML = '<option value="">Freitext-Bewertung (kein Formular)</option>' +
                forms.map(f => `<option value="${f.id}">${(f.title_de||'').replace(/</g,'&lt;')}</option>`).join('');
            sel.value = current;
        });
    }).catch(e => console.error('Formulare laden fehlgeschlagen', e));
}

function toggleEvalRole(prefix) {
    const checked = document.getElementById(prefix + 'RequiresEval').checked;
    document.getElementById(prefix + 'EvalRoleWrap').classList.toggle('d-none', !checked);
    document.getElementById(prefix + 'EvalFormWrap').classList.toggle('d-none', !checked);
    document.getElementById(prefix + 'DoubleEvalWrap').classList.toggle('d-none', !checked);
    if (!checked) { document.getElementById(prefix + 'DoubleEval').checked = false; }
    toggleDoubleEval(prefix);
}

function toggleDoubleEval(prefix) {
    const reqEval = document.getElementById(prefix + 'RequiresEval').checked;
    const dbl = document.getElementById(prefix + 'DoubleEval').checked;
    document.getElementById(prefix + 'EvalRole2Wrap').classList.toggle('d-none', !(reqEval && dbl));
}

function toggleApprover(prefix) {
    const checked = document.getElementById(prefix + 'RequiresApproval').checked;
    document.getElementById(prefix + 'ApproverWrap').classList.toggle('d-none', !checked);
}

function toggleApprover2(prefix) {
    const checked = document.getElementById(prefix + 'RequiresApproval2').checked;
    document.getElementById(prefix + 'Approver2Wrap').classList.toggle('d-none', !checked);
}

function openAddMilestoneModal() {
    document.getElementById('addMilestoneForm').reset();
    document.getElementById('addAllowUpload').checked = true;
    document.querySelector('#addMilestoneModal .modal-title').textContent = 'Meilenstein hinzufügen';
    toggleEvalRole('add');
    toggleApprover('add');
    toggleApprover2('add');
    new bootstrap.Modal(document.getElementById('addMilestoneModal')).show();
}

// Öffnet das Hinzufügen-Modal, vorbefüllt mit allen Werten der Vorlage —
// die Kopie durchläuft die normale Anlage-Validierung.
function copyMilestone(m) {
    const form = document.getElementById('addMilestoneForm');
    form.reset();
    document.querySelector('#addMilestoneModal .modal-title').textContent = 'Meilenstein kopieren';
    form.querySelector('[name="label"]').value = m.label + ' (Kopie)';
    form.querySelector('[name="label_fr"]').value = m.label_fr ? m.label_fr + ' (copie)' : '';
    form.querySelector('[name="due_at"]').value = toLocalInput(m.due_at);
    form.querySelector('[name="responsible_role"]').value = m.responsible_role;
    document.getElementById('addAppliesTo').value = m.applies_to || 'all';
    document.getElementById('addAllowUpload').checked = !!m.allow_upload;
    document.getElementById('addAllowUpdate').checked = !!m.allow_update;
    document.getElementById('addRequiresEval').checked = !!m.requires_evaluation;
    document.getElementById('addEvalRole').value = m.evaluator_role || '';
    document.getElementById('addEvalForm').value = m.evaluation_form_id || '';
    document.getElementById('addDoubleEval').checked = !!m.double_evaluation;
    document.getElementById('addEvalRole2').value = m.evaluator_role_2 || '';
    document.getElementById('addRequiresApproval').checked = !!m.requires_approval;
    document.getElementById('addApproverRole').value = m.approver_role || '';
    document.getElementById('addRequiresApproval2').checked = !!m.requires_approval_2;
    document.getElementById('addApproverRole2').value = m.approver_role_2 || '';
    document.getElementById('addIsTransferProject').checked = !!m.is_transfer_project;
    document.getElementById('addFeedbackFormEnabled').checked = !!m.feedback_form_enabled;
    document.getElementById('addReminderStartAt').value    = toLocalInput(m.reminder_start_at);
    document.getElementById('addReminderPeriodDays').value = m.reminder_period_days || 7;
    document.getElementById('addSingleDueAt').value        = toLocalInput(m.single_due_at);
    document.getElementById('addFirstDueAt').value         = toLocalInput(m.first_due_at);
    document.getElementById('addSecondDueAt').value        = toLocalInput(m.second_due_at);
    document.getElementById('addFinalDueAt').value         = toLocalInput(m.final_due_at);
    document.getElementById('addFeedbackDueAt').value      = toLocalInput(m.feedback_due_at);
    const addCatSelect = document.getElementById('addUploadCategories');
    if (addCatSelect) {
        const assigned = new Set((m.uploadCategories || []).map(c => c.id));
        Array.from(addCatSelect.options).forEach(opt => { opt.selected = assigned.has(parseInt(opt.value, 10)); });
    }
    toggleEvalRole('add');
    toggleApprover('add');
    toggleApprover2('add');
    new bootstrap.Modal(document.getElementById('addMilestoneModal')).show();
}

function editMilestone(m) {
    document.getElementById('editMilestoneId').value = m.id;
    document.getElementById('editMilestoneLabel').value = m.label;
    document.getElementById('editMilestoneLabelFr').value = m.label_fr || '';
    document.getElementById('editMilestoneDueAt').value = toLocalInput(m.due_at);
    document.getElementById('editMilestoneRole').value = m.responsible_role;
    document.getElementById('editAppliesTo').value = m.applies_to || 'all';
    document.getElementById('editAllowUpload').checked = !!m.allow_upload;
    document.getElementById('editAllowUpdate').checked = !!m.allow_update;
    document.getElementById('editRequiresEval').checked = !!m.requires_evaluation;
    document.getElementById('editEvalRole').value = m.evaluator_role || '';
    document.getElementById('editEvalForm').value = m.evaluation_form_id || '';
    document.getElementById('editDoubleEval').checked = !!m.double_evaluation;
    document.getElementById('editEvalRole2').value = m.evaluator_role_2 || '';
    document.getElementById('editRequiresApproval').checked = !!m.requires_approval;
    document.getElementById('editApproverRole').value = m.approver_role || '';
    document.getElementById('editRequiresApproval2').checked = !!m.requires_approval_2;
    document.getElementById('editApproverRole2').value = m.approver_role_2 || '';
    document.getElementById('editIsTransferProject').checked = !!m.is_transfer_project;
    document.getElementById('editFeedbackFormEnabled').checked = !!m.feedback_form_enabled;
    // Snapshot der Originalwerte für die Rückfrage-Logik beim Speichern.
    window.__editOriginal = {
        due_at:            toLocalInput(m.due_at),
        reminder_start_at: toLocalInput(m.reminder_start_at),
        single_due_at:     toLocalInput(m.single_due_at),
        first_due_at:      toLocalInput(m.first_due_at),
        second_due_at:     toLocalInput(m.second_due_at),
        final_due_at:      toLocalInput(m.final_due_at),
        feedback_due_at:   toLocalInput(m.feedback_due_at),
    };
    document.getElementById('editReminderStartAt').value    = toLocalInput(m.reminder_start_at);
    document.getElementById('editReminderPeriodDays').value = m.reminder_period_days || '';
    document.getElementById('editSingleDueAt').value        = toLocalInput(m.single_due_at);
    document.getElementById('editFirstDueAt').value         = toLocalInput(m.first_due_at);
    document.getElementById('editSecondDueAt').value        = toLocalInput(m.second_due_at);
    document.getElementById('editFinalDueAt').value         = toLocalInput(m.final_due_at);
    document.getElementById('editFeedbackDueAt').value      = toLocalInput(m.feedback_due_at);
    const overrideAllEl = document.getElementById('editOverrideAll');
    if (overrideAllEl) overrideAllEl.checked = false;
    const editCatSelect = document.getElementById('editUploadCategories');
    if (editCatSelect) {
        const assigned = new Set((m.uploadCategories || []).map(c => c.id));
        Array.from(editCatSelect.options).forEach(opt => { opt.selected = assigned.has(parseInt(opt.value, 10)); });
    }
    toggleEvalRole('edit');
    toggleApprover('edit');
    toggleApprover2('edit');
    const apply = document.getElementById('editApplyToExisting');
    if (apply) apply.checked = false;
    new bootstrap.Modal(document.getElementById('editMilestoneModal')).show();
}

// Convert checkbox form values ('on'/undefined) to real booleans
function normalizeConfig(data) {
    data.allow_upload = !!data.allow_upload;
    data.allow_update = !!data.allow_update;
    data.requires_evaluation = !!data.requires_evaluation;
    if (!data.requires_evaluation) { data.evaluator_role = null; data.evaluation_form_id = null; }
    if (data.evaluation_form_id === '') data.evaluation_form_id = null;
    data.double_evaluation = !!data.double_evaluation && data.requires_evaluation;
    if (!data.double_evaluation) data.evaluator_role_2 = null;
    data.requires_approval = !!data.requires_approval;
    if (!data.requires_approval) data.approver_role = null;
    data.requires_approval_2 = !!data.requires_approval_2;
    if (!data.requires_approval_2) data.approver_role_2 = null;
    data.is_transfer_project = !!data.is_transfer_project;
    data.feedback_form_enabled = !!data.feedback_form_enabled;
    return data;
}

function deleteMilestone(id, label) {
    document.getElementById('deleteMilestoneId').value = id;
    document.getElementById('deleteMilestoneLabel').textContent = label;
    document.getElementById('keepUploadedYes').checked = true;
    new bootstrap.Modal(document.getElementById('deleteMilestoneModal')).show();
}

document.getElementById('addMilestoneForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const data = normalizeConfig(Object.fromEntries(new FormData(this)));
    data.applyToExisting = !!data.applyToExisting;
    data.upload_categories = Array.from(document.getElementById('addUploadCategories').selectedOptions).map(o => o.value);

    fetch(`/api/years/${selectedYearId}/milestones`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) location.reload();
        else alert('Fehler: ' + (d.message || 'Unbekannt'));
    })
    .catch(err => { console.error(err); alert('Fehler beim Hinzufügen'); });
});

document.getElementById('editMilestoneForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const data = normalizeConfig(Object.fromEntries(new FormData(this)));
    data.applyToExisting = !!data.applyToExisting;
    data.overrideAll = !!data.overrideAll;
    data.upload_categories = Array.from(document.getElementById('editUploadCategories').selectedOptions).map(o => o.value);
    const id = data.id; delete data.id;

    // Rückfrage bei applyToExisting + Datum-Änderung: soll auch Overrides überschrieben werden?
    // Nur einblenden, wenn overrideAll nicht bereits vom Nutzer angeklickt wurde.
    const dateChanged = (
        (data.due_at || '') !== (window.__editOriginal?.due_at || '') ||
        (data.reminder_start_at || '') !== (window.__editOriginal?.reminder_start_at || '') ||
        (data.single_due_at || '') !== (window.__editOriginal?.single_due_at || '') ||
        (data.first_due_at || '') !== (window.__editOriginal?.first_due_at || '') ||
        (data.second_due_at || '') !== (window.__editOriginal?.second_due_at || '') ||
        (data.final_due_at || '') !== (window.__editOriginal?.final_due_at || '') ||
        (data.feedback_due_at || '') !== (window.__editOriginal?.feedback_due_at || '')
    );
    if (data.applyToExisting && dateChanged && !data.overrideAll) {
        const proceed = confirm(
            'Es gibt möglicherweise Diplomarbeiten mit individuell überschriebenen Terminen.\n\n' +
            '- „OK" behält die individuellen Überschreibungen bei (nur nicht-überschriebene Termine werden aktualisiert).\n' +
            '- „Abbrechen" bricht das Speichern ab.\n\n' +
            'Wenn du ALLE Overrides ersetzen möchtest, aktiviere „Auch individuell überschriebene Termine ersetzen".'
        );
        if (!proceed) return;
    }

    fetch(`/api/milestones/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) location.reload();
        else alert('Fehler: ' + (d.message || 'Unbekannt'));
    })
    .catch(err => { console.error(err); alert('Fehler beim Speichern'); });
});

document.getElementById('deleteMilestoneForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const id = document.getElementById('deleteMilestoneId').value;
    const keepUploaded = document.querySelector('input[name="keepUploaded"]:checked').value === 'true';

    fetch(`/api/milestones/${id}?keepUploaded=${keepUploaded}`, {
        method: 'DELETE'
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) location.reload();
        else alert('Fehler: ' + (d.message || 'Unbekannt'));
    })
    .catch(err => { console.error(err); alert('Fehler beim Löschen'); });
});

loadEvaluationForms();
</script>

<%- include('../partials/footer') %>
