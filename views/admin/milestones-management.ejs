<%- include('../partials/header', { title: 'Meilenstein-Verwaltung - DABuddy', user: user }) %>

<%
const ROLE_LABELS = { student: 'Student', coach: 'Coach', expert: 'ExpertIn', admin: 'Administrator', department_lead: 'FachbereichsleiterIn', field_project_coach: 'Field Project Coach' };
%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Meilenstein-Verwaltung</li>
            </ol>
        </nav>
        <h1>Meilenstein-Verwaltung</h1>
    </div>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear.year %>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-flag"></i> Meilensteine für <%= selectedYear.year %>
        </h5>
        <button class="btn btn-success" onclick="openAddMilestoneModal()">
            <i class="bi bi-plus"></i> Meilenstein hinzufügen
        </button>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i>
            Diese Meilensteine werden als Vorlage für alle neuen Diplomarbeiten in <%= selectedYear.year %> verwendet.
            Aktuell existieren <strong><%= thesesCount %></strong> Diplomarbeiten in diesem Diplomjahr.
        </div>

        <% if (milestones.length === 0) { %>
            <div class="text-center py-4">
                <i class="bi bi-flag text-muted" style="font-size: 48px;"></i>
                <p class="text-muted mt-2">Noch keine Meilensteine erfasst.</p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Bezeichnung</th>
                            <th>Termin</th>
                            <th>Verantwortliche Rolle</th>
                            <th>Konfiguration</th>
                            <th>Aktionen</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% milestones.forEach(function(m) { %>
                            <tr>
                                <td><strong><%= m.label %></strong></td>
                                <td>
                                    <i class="bi bi-calendar-event"></i>
                                    <%= new Date(m.due_at).toLocaleDateString('de-CH') %>
                                    <%= new Date(m.due_at).toLocaleTimeString('de-CH', { hour: '2-digit', minute: '2-digit' }) %>
                                </td>
                                <td>
                                    <span class="badge bg-secondary"><%= ROLE_LABELS[m.responsible_role] || m.responsible_role %></span>
                                </td>
                                <td>
                                    <% if (m.allow_upload) { %>
                                        <span class="badge bg-success" title="Upload erlaubt"><i class="bi bi-upload"></i> Upload</span>
                                    <% } else { %>
                                        <span class="badge bg-light text-muted" title="Kein Upload"><i class="bi bi-upload"></i> kein Upload</span>
                                    <% } %>
                                    <% if (m.allow_update) { %>
                                        <span class="badge bg-info text-dark" title="Aktualisierung erlaubt"><i class="bi bi-arrow-repeat"></i> Update</span>
                                    <% } %>
                                    <% if (m.requires_evaluation) { %>
                                        <span class="badge bg-warning text-dark" title="Bewertung durch <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %>">
                                            <i class="bi bi-star"></i> Bewertung: <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %>
                                        </span>
                                        <% if (m.evaluationForm) { %>
                                            <span class="badge bg-primary" title="Bewertungsformular">
                                                <i class="bi bi-clipboard-check"></i> <%= m.evaluationForm.title_de %>
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-light text-muted">Freitext</span>
                                        <% } %>
                                        <% if (m.double_evaluation) { %>
                                            <span class="badge bg-primary" title="Doppelbewertung durch <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %> und <%= ROLE_LABELS[m.evaluator_role_2] || m.evaluator_role_2 %>">
                                                <i class="bi bi-people"></i> Doppelbewertung: <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %> + <%= ROLE_LABELS[m.evaluator_role_2] || m.evaluator_role_2 %>
                                            </span>
                                        <% } %>
                                    <% } %>
                                    <% if (m.requires_approval) { %>
                                        <span class="badge bg-dark" title="Freigabe 1 durch <%= ROLE_LABELS[m.approver_role] || m.approver_role %>">
                                            <i class="bi bi-unlock"></i> Freigabe 1: <%= ROLE_LABELS[m.approver_role] || m.approver_role %>
                                        </span>
                                    <% } %>
                                    <% if (m.requires_approval_2) { %>
                                        <span class="badge bg-dark" title="Freigabe 2 durch <%= ROLE_LABELS[m.approver_role_2] || m.approver_role_2 %>">
                                            <i class="bi bi-unlock"></i> Freigabe 2: <%= ROLE_LABELS[m.approver_role_2] || m.approver_role_2 %>
                                        </span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <button class="btn btn-outline-primary btn-sm" onclick='editMilestone(<%- JSON.stringify(m) %>)'>
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" onclick="deleteMilestone(<%= m.id %>, '<%= m.label.replace(/'/g, "\\'") %>')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<!-- Hinzufügen Modal -->
<div class="modal fade" id="addMilestoneModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Meilenstein hinzufügen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addMilestoneForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Bezeichnung</label>
                        <input type="text" class="form-control" name="label" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Termin (Datum & Zeit)</label>
                        <input type="datetime-local" class="form-control" name="due_at" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Verantwortliche Rolle</label>
                        <select class="form-select" name="responsible_role" required>
                            <option value="">Rolle auswählen...</option>
                            <option value="student">Student</option>
                            <option value="coach">Coach</option>
                            <option value="expert">ExpertIn</option>
                            <option value="department_lead">FachbereichsleiterIn</option>
                            <option value="field_project_coach">Field Project Coach</option>
                            <option value="admin">Administrator</option>
                        </select>
                    </div>
                    <hr>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="allow_upload" id="addAllowUpload" checked>
                        <label class="form-check-label" for="addAllowUpload">Dokument-Upload durch Verantwortliche erlaubt</label>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="allow_update" id="addAllowUpdate">
                        <label class="form-check-label" for="addAllowUpdate">Aktualisierung (neue Version) erlaubt</label>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="requires_evaluation" id="addRequiresEval" onchange="toggleEvalRole('add')">
                        <label class="form-check-label" for="addRequiresEval">Dokument wird bewertet</label>
                    </div>
                    <div class="mb-3 d-none" id="addEvalRoleWrap">
                        <label class="form-label">Bewertende Rolle</label>
                        <select class="form-select" name="evaluator_role" id="addEvalRole">
                            <option value="">Rolle auswählen...</option>
                            <option value="coach">Coach</option>
                            <option value="expert">ExpertIn</option>
                            <option value="department_lead">FachbereichsleiterIn</option>
                            <option value="field_project_coach">Field Project Coach</option>
                            <option value="admin">Administrator</option>
                        </select>
                    </div>
                    <div class="mb-3 d-none" id="addEvalFormWrap">
                        <label class="form-label">Bewertungsformular (optional)</label>
                        <select class="form-select" name="evaluation_form_id" id="addEvalForm">
                            <option value="">Freitext-Bewertung (kein Formular)</option>
                        </select>
                    </div>
                    <div class="form-check mb-2 d-none" id="addDoubleEvalWrap">
                        <input type="checkbox" class="form-check-input" name="double_evaluation" id="addDoubleEval" onchange="toggleDoubleEval('add')">
                        <label class="form-check-label" for="addDoubleEval">Doppelbewertung (zwei Rollen + finale Bewertung)</label>
                    </div>
                    <div class="mb-3 d-none" id="addEvalRole2Wrap">
                        <label class="form-label">Zweite bewertende Rolle</label>
                        <select class="form-select" name="evaluator_role_2" id="addEvalRole2">
                            <option value="">Rolle auswählen...</option>
                            <option value="coach">Coach</option>
                            <option value="expert">ExpertIn</option>
                            <option value="department_lead">FachbereichsleiterIn</option>
                            <option value="field_project_coach">Field Project Coach</option>
                            <option value="admin">Administrator</option>
                        </select>
                        <div class="form-text">Die erste bewertende Rolle ist oben gewählt. Beide Rollen müssen unterschiedlich sein.</div>
                    </div>
                    <hr>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="requires_approval" id="addRequiresApproval" onchange="toggleApprover('add')">
                        <label class="form-check-label" for="addRequiresApproval">Freigabe 1 erforderlich</label>
                    </div>
                    <div class="mb-3 d-none" id="addApproverWrap">
                        <label class="form-label">Freigebende Rolle (Freigabe 1)</label>
                        <select class="form-select" name="approver_role" id="addApproverRole">
                            <option value="">Rolle auswählen...</option>
                            <option value="student">Student</option>
                            <option value="coach">Coach</option>
                            <option value="expert">ExpertIn</option>
                            <option value="department_lead">FachbereichsleiterIn</option>
                            <option value="field_project_coach">Field Project Coach</option>
                            <option value="admin">Administrator</option>
                        </select>
                    </div>
                    <div class="form-check mb-2">
                        <input type="checkbox" class="form-check-input" name="requires_approval_2" id="addRequiresApproval2" onchange="toggleApprover2('add')">
                        <label class="form-check-label" for="addRequiresApproval2">Freigabe 2 erforderlich</label>
                    </div>
                    <div class="mb-3 d-none" id="addApprover2Wrap">
                        <label class="form-label">Freigebende Rolle (Freigabe 2)</label>
                        <select class="form-select" name="approver_role_2" id="addApproverRole2">
                            <option value="">Rolle auswählen...</option>
                            <option value="student">Student</option>
                            <option value="coach">Coach</option>
                            <option value="expert">ExpertIn</option>
                            <option value="department_lead">FachbereichsleiterIn</option>
                            <option value="field_project_coach">Field Project Coach</option>
                            <option value="admin">Administrator</option>
                        </select>
                    </div>
                    <hr>
                    <% if (thesesCount > 0) { %>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" name="applyToExisting" id="addApplyToExisting" checked>
                        <label class="form-check-label" for="addApplyToExisting">
                            Auf bereits existierende Diplomarbeiten anwenden (<%= thesesCount %>)
                        </label>
                    </div>
                    <% } %>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Hinzufügen</button>
                </div>
            </form>
        </div>
    </div>
</div>

