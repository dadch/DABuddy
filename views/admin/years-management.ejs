<%- include('../partials/header', { title: 'Diplomjahr-Verwaltung - ThesisBuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Diplomjahre</li>
            </ol>
        </nav>
        <h1>Diplomjahr-Verwaltung</h1>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-calendar"></i> Diplomjahre</h5>
        <button class="btn btn-success" onclick="openAddYearModal()">
            <i class="bi bi-plus"></i> Diplomjahr hinzufügen
        </button>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i>
            Das als <strong>aktuell</strong> markierte Diplomjahr wird neuen Benutzern beim Login automatisch ausgewählt.
            Administratoren und FachbereichsleiterInnen können im Dashboard zwischen den Diplomjahren wechseln.
        </div>
        <div id="yearsList"><p class="text-muted">Wird geladen…</p></div>
    </div>
</div>

<!-- Hinzufügen -->
<div class="modal fade" id="addYearModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Diplomjahr hinzufügen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addYearForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="newYearInput" class="form-label">Jahr (z. B. 2027)</label>
                        <input type="number" class="form-control" id="newYearInput" min="2000" max="2100" required>
                    </div>
                    <div class="mb-3">
                        <label for="newYearLabelDe" class="form-label">Bezeichnung (Deutsch)</label>
                        <input type="text" class="form-control" id="newYearLabelDe" placeholder="optional – Fallback auf Jahreszahl">
                    </div>
                    <div class="mb-3">
                        <label for="newYearLabelFr" class="form-label">Bezeichnung (Französisch)</label>
                        <input type="text" class="form-control" id="newYearLabelFr" placeholder="optional – Fallback auf Jahreszahl">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Anlegen</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bearbeiten -->
<div class="modal fade" id="editYearModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Diplomjahr bearbeiten</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editYearForm">
                <div class="modal-body">
                    <input type="hidden" id="editYearId">
                    <div class="mb-3">
                        <label class="form-label">Jahr</label>
                        <input type="text" class="form-control" id="editYearReadonly" readonly>
                    </div>
                    <div class="mb-3">
                        <label for="editYearLabelDe" class="form-label">Bezeichnung (Deutsch)</label>
                        <input type="text" class="form-control" id="editYearLabelDe" placeholder="optional – Fallback auf Jahreszahl">
                    </div>
                    <div class="mb-3">
                        <label for="editYearLabelFr" class="form-label">Bezeichnung (Französisch)</label>
                        <input type="text" class="form-control" id="editYearLabelFr" placeholder="optional – Fallback auf Jahreszahl">
                    </div>
                    <hr>
                    <h6 class="mb-1"><i class="bi bi-file-earmark-text"></i> Aufgabenstellungs-Termine</h6>
                    <div class="form-text mb-2">
                        Meilenstein 1 = Ausgabe der Aufgabenstellung (Titelseite und «Administratives»; ab diesem
                        Zeitpunkt steht das PDF Studierenden zum Download bereit). Meilenstein 2 = Abgabe der Diplomarbeit.
                    </div>
                    <div class="row g-2 mb-2">
                        <div class="col-md-6">
                            <label class="form-label small">Meilenstein 1 — Vollzeit</label>
                            <input type="datetime-local" class="form-control" id="editYearAssignM1Ft">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Meilenstein 1 — Berufsbegleitend</label>
                            <input type="datetime-local" class="form-control" id="editYearAssignM1Pt">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Meilenstein 2 — Vollzeit</label>
                            <input type="datetime-local" class="form-control" id="editYearAssignM2Ft">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Meilenstein 2 — Berufsbegleitend</label>
                            <input type="datetime-local" class="form-control" id="editYearAssignM2Pt">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Diplomjahr löschen Modal (kaskadiert, mit Sicherheitscode) -->
<div class="modal fade" id="deleteYearModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle"></i> Diplomjahr <span id="deleteYearLabel"></span> unwiderruflich löschen</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">Mit dem Diplomjahr werden <strong>unwiderruflich</strong> gelöscht:</p>
                <ul id="deleteYearSummary" class="mb-3"></ul>
                <p class="mb-1">Zur Bestätigung den folgenden Code eingeben:</p>
                <p class="mb-2"><code id="deleteYearCode" class="fs-5 user-select-all"></code></p>
                <input type="text" class="form-control" id="deleteYearCodeInput" autocomplete="off"
                       placeholder="10-Zeichen-Code abtippen">
                <div id="deleteYearError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" class="btn btn-danger" id="deleteYearConfirmBtn" disabled onclick="confirmDeleteYear()">
                    <i class="bi bi-trash"></i> Unwiderruflich löschen
                </button>
            </div>
        </div>
    </div>
</div>

<script>
function loadYears() {
    fetch('/api/years')
        .then(r => r.json())
        .then(years => {
            const el = document.getElementById('yearsList');
            if (!Array.isArray(years) || years.length === 0) {
                el.innerHTML = '<p class="text-muted mb-0">Noch keine Diplomjahre erfasst.</p>';
                return;
            }
            el.innerHTML = `
                <div class="table-responsive"><table class="table table-striped">
                    <thead><tr>
                        <th>Jahr</th>
                        <th>Bezeichnung DE</th>
                        <th>Bezeichnung FR</th>
                        <th>Status</th>
                        <th>Diplomarbeiten</th>
                        <th>Studierende</th>
                        <th>Meilenstein-Vorlagen</th>
                        <th>Aktionen</th>
                    </tr></thead>
                    <tbody>
                        ${years.map(y => `
                            <tr>
                                <td><strong>${y.year}</strong></td>
                                <td>${escapeHtml(y.label_de || '')}</td>
                                <td>${escapeHtml(y.label_fr || '')}</td>
                                <td>${y.is_current
                                    ? '<span class="badge bg-success"><i class="bi bi-check-circle"></i> Aktuell</span>'
                                    : '<span class="badge bg-secondary">—</span>'}</td>
                                <td>${y.thesesCount}</td>
                                <td>${y.studentsCount}</td>
                                <td>${y.milestonesCount}</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm me-1" onclick='editYear(${JSON.stringify(y)})'><i class="bi bi-pencil"></i></button>
                                    ${y.is_current
                                      ? ''
                                      : `<button class="btn btn-outline-success btn-sm me-1" onclick="setYearCurrent(${y.id})"><i class="bi bi-check2-circle"></i> Als aktuell setzen</button>`}
                                    ${y.is_current
                                      ? ''
                                      : `<button class="btn btn-outline-danger btn-sm" onclick='openDeleteYearModal(${JSON.stringify(y)})'><i class="bi bi-trash"></i></button>`}
                                </td>
                            </tr>
                        `).join('')}
                    </tbody>
                </table></div>`;
        })
        .catch(err => {
            console.error(err);
            document.getElementById('yearsList').innerHTML = '<div class="alert alert-danger">Fehler beim Laden</div>';
        });
}

function openAddYearModal() {
    document.getElementById('addYearForm').reset();
    new bootstrap.Modal(document.getElementById('addYearModal')).show();
}

function escapeHtml(s) {
    return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}

document.getElementById('addYearForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const year = parseInt(document.getElementById('newYearInput').value, 10);
    const label_de = document.getElementById('newYearLabelDe').value.trim();
    const label_fr = document.getElementById('newYearLabelFr').value.trim();
    fetch('/api/years', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ year, label_de, label_fr }) })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                bootstrap.Modal.getInstance(document.getElementById('addYearModal')).hide();
                loadYears();
            } else alert('Fehler: ' + (d.message || 'Unbekannt'));
        })
        .catch(err => { console.error(err); alert('Fehler beim Anlegen'); });
});

function toLocalInput(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    const pad = n => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function editYear(y) {
    document.getElementById('editYearId').value = y.id;
    document.getElementById('editYearReadonly').value = y.year;
    document.getElementById('editYearLabelDe').value = y.label_de || '';
    document.getElementById('editYearLabelFr').value = y.label_fr || '';
    document.getElementById('editYearAssignM1Ft').value = toLocalInput(y.assignment_m1_fulltime);
    document.getElementById('editYearAssignM1Pt').value = toLocalInput(y.assignment_m1_parttime);
    document.getElementById('editYearAssignM2Ft').value = toLocalInput(y.assignment_m2_fulltime);
    document.getElementById('editYearAssignM2Pt').value = toLocalInput(y.assignment_m2_parttime);
    new bootstrap.Modal(document.getElementById('editYearModal')).show();
}

document.getElementById('editYearForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const id = document.getElementById('editYearId').value;
    const label_de = document.getElementById('editYearLabelDe').value.trim();
    const label_fr = document.getElementById('editYearLabelFr').value.trim();
    const body = {
        label_de, label_fr,
        assignment_m1_fulltime: document.getElementById('editYearAssignM1Ft').value,
        assignment_m1_parttime: document.getElementById('editYearAssignM1Pt').value,
        assignment_m2_fulltime: document.getElementById('editYearAssignM2Ft').value,
        assignment_m2_parttime: document.getElementById('editYearAssignM2Pt').value,
    };
    fetch('/api/years/' + id, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                bootstrap.Modal.getInstance(document.getElementById('editYearModal')).hide();
                loadYears();
            } else alert('Fehler: ' + (d.message || 'Unbekannt'));
        })
        .catch(err => { console.error(err); alert('Fehler beim Speichern'); });
});

function setYearCurrent(id) {
    if (!confirm('Dieses Diplomjahr global als aktuell setzen?')) return;
    fetch('/api/years/' + id + '/current', { method: 'PUT' })
        .then(r => r.json())
        .then(d => { if (d.success) loadYears(); else alert('Fehler: ' + (d.message || 'Unbekannt')); })
        .catch(err => { console.error(err); alert('Fehler beim Setzen'); });
}

// Kaskadierendes Löschen mit strenger Sicherheitsabfrage: Der Admin muss
// einen zufälligen 10-Zeichen-Code abtippen, bevor gelöscht werden kann.
let _deleteYearId = null;
let _deleteYearCode = '';

function _randomCode(len) {
    // Ohne verwechselbare Zeichen (I, O, 0, 1)
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
    let out = '';
    const rnd = new Uint32Array(len);
    crypto.getRandomValues(rnd);
    for (let i = 0; i < len; i++) out += chars[rnd[i] % chars.length];
    return out;
}

function openDeleteYearModal(y) {
    _deleteYearId = y.id;
    _deleteYearCode = _randomCode(10);
    document.getElementById('deleteYearLabel').textContent = y.label_de || y.year;
    document.getElementById('deleteYearSummary').innerHTML =
        `<li><strong>${y.thesesCount}</strong> Diplomarbeit(en) inkl. aller Dokumente, Bewertungen und Protokolle</li>` +
        `<li><strong>${y.studentsCount}</strong> Studierende</li>` +
        `<li><strong>${y.milestonesCount}</strong> Meilenstein-Vorlage(n)</li>`;
    document.getElementById('deleteYearCode').textContent = _deleteYearCode;
    const input = document.getElementById('deleteYearCodeInput');
    input.value = '';
    document.getElementById('deleteYearConfirmBtn').disabled = true;
    document.getElementById('deleteYearError').classList.add('d-none');
    new bootstrap.Modal(document.getElementById('deleteYearModal')).show();
    setTimeout(() => input.focus(), 400);
}

document.getElementById('deleteYearCodeInput').addEventListener('input', function() {
    document.getElementById('deleteYearConfirmBtn').disabled =
        this.value.trim().toUpperCase() !== _deleteYearCode;
});

function confirmDeleteYear() {
    const errEl = document.getElementById('deleteYearError');
    errEl.classList.add('d-none');
    const btn = document.getElementById('deleteYearConfirmBtn');
    btn.disabled = true;
    fetch('/api/years/' + _deleteYearId + '?cascade=true', { method: 'DELETE' })
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                bootstrap.Modal.getInstance(document.getElementById('deleteYearModal')).hide();
                loadYears();
            } else {
                errEl.textContent = d.message || 'Löschen fehlgeschlagen';
                errEl.classList.remove('d-none');
            }
        })
        .catch(err => {
            console.error(err);
            errEl.textContent = 'Netzwerkfehler beim Löschen';
            errEl.classList.remove('d-none');
        });
}

loadYears();
</script>

<%- include('../partials/footer') %>
