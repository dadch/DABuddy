function loadUserOptions(departmentId = null) {
    return fetch('/api/users')
        .then(response => response.json())
        .then(users => {
            let filteredUsers = users;
            if (departmentId) {
                filteredUsers = users.filter(user =>
                    user.departments && user.departments.some(dept => dept.id == departmentId)
                );
            }

            const students = filteredUsers.filter(user => user.role === 'student');
            const coaches = filteredUsers.filter(user => user.role === 'coach');
            const experts = filteredUsers.filter(user => user.role === 'expert');
            const fieldProjectCoaches = filteredUsers.filter(user => user.role === 'field_project_coach');

            ['thesisStudents', 'editThesisStudents'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">Studenten auswählen...</option>';
                    students.forEach(student => {
                        const option = document.createElement('option');
                        option.value = student.id;
                        option.textContent = `${student.firstname} ${student.name}`;
                        select.appendChild(option);
                    });
                }
            });

            ['thesisCoach', 'editThesisCoach'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">Coach auswählen...</option>';
                    coaches.forEach(coach => {
                        const option = document.createElement('option');
                        option.value = coach.id;
                        option.textContent = `${coach.firstname} ${coach.name}`;
                        select.appendChild(option);
                    });
                }
            });

            ['thesisExpert', 'editThesisExpert'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">ExpertIn auswählen...</option>';
                    experts.forEach(expert => {
                        const option = document.createElement('option');
                        option.value = expert.id;
                        option.textContent = `${expert.firstname} ${expert.name}`;
                        select.appendChild(option);
                    });
                }
            });

            ['thesisFieldProjectCoach', 'editThesisFieldProjectCoach'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">Field Project Coach auswählen...</option>';
                    fieldProjectCoaches.forEach(fpc => {
                        const option = document.createElement('option');
                        option.value = fpc.id;
                        option.textContent = `${fpc.firstname} ${fpc.name}`;
                        select.appendChild(option);
                    });
                }
            });
        })
        .catch(error => {
            console.error('Fehler beim Laden der Benutzeroptionen:', error);
        });
}

function roleLabel(role) {
    const labels = {
        student: 'Student',
        coach: 'Coach',
        expert: 'ExpertIn',
        admin: 'Administrator',
        department_lead: 'FachbereichsleiterIn',
        field_project_coach: 'Field Project Coach'
    };
    return labels[role] || role;
}

function loadUsers() {
    fetch('/api/users')
        .then(response => response.json())
        .then(users => {
            const usersList = document.getElementById('usersList');
            usersList.innerHTML = `
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Benutzername</th>
                                <th>Name</th>
                                <th>E-Mail</th>
                                <th>Rolle</th>
                                <th>Fachbereiche</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${users.map(user => `
                                <tr>
                                    <td>${user.username}</td>
                                    <td>${user.firstname} ${user.name}</td>
                                    <td>${user.email}</td>
                                    <td><span class="badge bg-secondary">${roleLabel(user.role)}</span></td>
                                    <td>
                                        ${user.departments && user.departments.length > 0
