<%- include('../partials/header', { title: 'Administrator-Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Diplomarbeit-Verwaltung</h1>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear %>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-mortarboard"></i> Diplomarbeiten gesamt
                </h5>
                <h3 class="text-primary"><%= theses.length %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-people"></i> Aktionen
                </h5>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-success" onclick="openAddThesisModal()">
                        <i class="bi bi-plus"></i> Diplomarbeit hinzufügen
                    </button>
                    <a href="/dashboard/admin/milestones" class="btn btn-outline-primary">
                        <i class="bi bi-flag"></i> Meilensteine
                    </a>
                    <a href="/dashboard/admin/evaluation-forms" class="btn btn-outline-primary">
                        <i class="bi bi-clipboard-check"></i> Bewertungsformulare
                    </a>
                    <button type="button" class="btn btn-info" onclick="openUserManagementModal()">
                        <i class="bi bi-person-gear"></i> Benutzer verwalten
                    </button>
                    <button type="button" class="btn btn-warning" onclick="openDepartmentManagementModal()">
                        <i class="bi bi-building"></i> Fachbereiche verwalten
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-4">
        <form method="GET" action="/dashboard" class="d-flex">
            <select name="department" class="form-select me-2" onchange="this.form.submit()">
                <option value="">Alle Fachbereiche</option>
                <% departments.forEach(function(dept) { %>
                    <option value="<%= dept.id %>" <%= selectedDepartment == dept.id ? 'selected' : '' %>>
                        <%= dept.name %>
                    </option>
                <% }); %>
            </select>
            <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-funnel"></i>
            </button>
        </form>
    </div>
</div>

<% if (theses.length === 0) { %>
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        Keine Diplomarbeiten für die ausgewählten Kriterien gefunden.
    </div>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Titel der Diplomarbeit</th>
                    <th>Fachbereich</th>
                    <th>Studenten</th>
                    <th>Coaches</th>
                    <th>Field Project Coaches</th>
                    <th>Experten</th>
                    <th>Auftraggeber</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                <% theses.forEach(function(thesis) { %>
                    <tr>
                        <td>
                            <strong><%= thesis.title %></strong>
                        </td>
                        <td><%= thesis.department.name %></td>
                        <td>
                            <% if (thesis.students.length > 0) { %>
                                <% thesis.students.forEach(function(student, index) { %>
                                    <span class="badge bg-primary me-1"><%= student.firstname %> <%= student.name %></span>
                                <% }); %>
                            <% } else { %>
                                <span class="text-muted">Keine Studenten zugewiesen</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (thesis.coaches.length > 0) { %>
                                <% thesis.coaches.forEach(function(coach, index) { %>
                                    <span class="badge bg-success me-1"><%= coach.firstname %> <%= coach.name %></span>
                                <% }); %>
                            <% } else { %>
                                <span class="text-muted">Keine Coaches zugewiesen</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) { %>
                                <% thesis.fieldProjectCoaches.forEach(function(fpc, index) { %>
                                    <span class="badge bg-warning text-dark me-1"><%= fpc.firstname %> <%= fpc.name %></span>
                                <% }); %>
                            <% } else { %>
                                <span class="text-muted">Keine zugewiesen</span>
                            <% } %>
                        </td>
                        <td>
                            <% if (thesis.experts.length > 0) { %>
                                <% thesis.experts.forEach(function(expert, index) { %>
                                    <span class="badge bg-info me-1"><%= expert.firstname %> <%= expert.name %></span>
                                <% }); %>
                            <% } else { %>
                                <span class="text-muted">Keine Experten zugewiesen</span>
                            <% } %>
                        </td>
                        <td><%= thesis.sponsor || '-' %></td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <button class="btn btn-outline-primary btn-sm" onclick="editThesis(<%= thesis.id %>)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteThesis(<%= thesis.id %>)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>

<!-- Diplomarbeit hinzufügen Modal -->
<div class="modal fade" id="addThesisModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Neue Diplomarbeit hinzufügen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addThesisForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="thesisTitle" class="form-label">Titel</label>
                        <input type="text" class="form-control" id="thesisTitle" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label for="thesisDepartment" class="form-label">Fachbereich</label>
                        <select class="form-select" id="thesisDepartment" name="department_id" required>
                            <option value="">Fachbereich auswählen</option>
                            <% departments.forEach(function(dept) { %>
                                <option value="<%= dept.id %>"><%= dept.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisSponsor" class="form-label">Auftraggeber (optional)</label>
                        <input type="text" class="form-control" id="thesisSponsor" name="sponsor">
                    </div>
                    <div class="mb-3">
                        <label for="thesisLanguage" class="form-label">Sprache der Diplomarbeit</label>
                        <select class="form-select" id="thesisLanguage" name="language">
                            <option value="de">Deutsch</option>
                            <option value="fr">Französisch</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisStudents" class="form-label">Studenten (max. 1-2)</label>
                        <select class="form-select" id="thesisStudents" name="students" multiple size="4">
                            <option value="">Studenten auswählen...</option>
                        </select>
                        <div class="form-text">Strg/Cmd halten, um mehrere Studenten auszuwählen (maximal 2)</div>
                    </div>
                    <div class="mb-3">
                        <label for="thesisCoach" class="form-label">Coach</label>
                        <select class="form-select" id="thesisCoach" name="coach">
                            <option value="">Coach auswählen...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisFieldProjectCoach" class="form-label">Field Project Coach</label>
                        <select class="form-select" id="thesisFieldProjectCoach" name="field_project_coach">
                            <option value="">Field Project Coach auswählen...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisExpert" class="form-label">ExpertIn</label>
                        <select class="form-select" id="thesisExpert" name="expert">
                            <option value="">ExpertIn auswählen...</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Diplomarbeit hinzufügen</button>
                </div>
            </form>
        </div>
    </div>
</div>

