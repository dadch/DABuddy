function editDepartment(id) {
    Promise.all([
        fetch(`/api/departments`).then(response => response.json()),
        loadDepartmentLeads()
    ])
    .then(([departments]) => {
        const department = departments.find(d => d.id === id);
        if (!department) {
            alert('Fachbereich nicht gefunden');
            return;
        }

        document.getElementById('editDepartmentId').value = department.id;
        document.getElementById('editDepartmentName').value = department.name;
        document.getElementById('editDepartmentLead').value = department.department_lead_id || '';

        new bootstrap.Modal(document.getElementById('editDepartmentModal')).show();
    })
    .catch(error => {
        console.error('Fehler beim Laden des Fachbereichs:', error);
        alert('Fehler beim Laden der Fachbereichsdaten');
    });
}

function deleteDepartment(id) {
    if (confirm('Möchten Sie diesen Fachbereich wirklich löschen? Wenn zugehörige Diplomarbeiten existieren, kann der Vorgang nicht rückgängig gemacht werden.')) {
        fetch(`/api/departments/${id}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                loadDepartments();
            } else {
                alert('Fehler beim Löschen des Fachbereichs: ' + (data.message || 'Unbekannter Fehler'));
            }
        })
        .catch(error => {
            console.error('Fehler beim Löschen des Fachbereichs:', error);
            alert('Fehler beim Löschen des Fachbereichs');
        });
    }
}

document.getElementById('addThesisForm').addEventListener('submit', function(e) {
    e.preventDefault();

    const studentsSelect = document.getElementById('thesisStudents');
    const selectedStudents = Array.from(studentsSelect.selectedOptions).map(option => option.value).filter(value => value !== '');

    if (selectedStudents.length > 2) {
        alert('Sie können maximal 2 Studenten einer Diplomarbeit zuweisen.');
        return;
    }

    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    data.students = selectedStudents;
    data.coach = document.getElementById('thesisCoach').value || null;
    data.expert = document.getElementById('thesisExpert').value || null;
    data.field_project_coach = document.getElementById('thesisFieldProjectCoach').value || null;

    fetch('/api/theses', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Fehler beim Hinzufügen der Diplomarbeit: ' + (data.message || 'Unbekannter Fehler'));
        }
    })
    .catch(error => {
        console.error('Fehler beim Hinzufügen der Diplomarbeit:', error);
        alert('Fehler beim Hinzufügen der Diplomarbeit');
    });
});

