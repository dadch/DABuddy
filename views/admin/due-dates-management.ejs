<%- include('../partials/header', { title: 'Document Due Dates Management - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Due Dates Management</li>
            </ol>
        </nav>
        <h1>Document Due Dates Management</h1>
    </div>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Academic Year: <%= selectedYear.year %>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-calendar-event"></i> Set Due Dates for <%= selectedYear.year %>
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    Set due dates for each document type in the current academic year. These dates will apply to all theses in <%= selectedYear.year %>.
                </div>

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Document Type</th>
                                <th>Current Due Date</th>
                                <th>New Due Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% documentTypes.forEach(function(docType) { %>
                                <tr>
                                    <td>
                                        <strong><%= docType %></strong>
                                    </td>
                                    <td>
                                        <% if (dueDateMap[docType]) { %>
                                            <span class="badge bg-success">
                                                <i class="bi bi-calendar-check"></i> <%= new Date(dueDateMap[docType]).toLocaleDateString() %>
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-warning">
                                                <i class="bi bi-calendar-x"></i> Not set
                                            </span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <input type="date" class="form-control" id="date-<%= docType.replace(/\s+/g, '-') %>" 
                                               value="<%= dueDateMap[docType] ? new Date(dueDateMap[docType]).toISOString().split('T')[0] : '' %>">
                                    </td>
                                    <td>
                                        <div class="btn-group">
                                            <button class="btn btn-primary btn-sm" onclick="setDueDate('<%= docType %>', '<%= docType.replace(/\s+/g, '-') %>')">
                                                <i class="bi bi-check-circle"></i> Set Date
                                            </button>
                                            <% if (dueDateMap[docType]) { %>
                                                <button class="btn btn-danger btn-sm" onclick="deleteDueDate('<%= docType %>')">
                                                    <i class="bi bi-trash"></i> Remove
                                                </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history"></i> Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Copy from Previous Year</h6>
                        <p class="text-muted">Copy due dates from another academic year to the current year.</p>
                        <div class="input-group">
                            <select class="form-select" id="copyFromYear">
                                <option value="">Select year to copy from...</option>
                                <% years.forEach(function(year) { %>
                                    <% if (year.id !== selectedYear.id) { %>
                                        <option value="<%= year.id %>"><%= year.year %></option>
                                    <% } %>
                                <% }); %>
                            </select>
                            <button class="btn btn-outline-secondary" onclick="copyFromYear()">
                                <i class="bi bi-copy"></i> Copy
                            </button>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <h6>Clear All Due Dates</h6>
                        <p class="text-muted">Remove all due dates for the current academic year.</p>
                        <button class="btn btn-outline-danger" onclick="clearAllDueDates()">
                            <i class="bi bi-trash"></i> Clear All
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const selectedYearId = <%= selectedYear.id %>;

function setDueDate(documentType, fieldId) {
    const dateInput = document.getElementById(`date-${fieldId}`);
    const dueDate = dateInput.value;
    
    if (!dueDate) {
        showAlert('Please select a due date.', 'warning');
        return;
    }
    
    fetch('/api/document-due-dates', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            yearId: selectedYearId,
            documentType: documentType,
            dueDate: dueDate
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showAlert(data.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showAlert(data.message || 'Failed to set due date', 'danger');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('An error occurred while setting the due date.', 'danger');
    });
}

function deleteDueDate(documentType) {
    if (!confirm(`Are you sure you want to remove the due date for "${documentType}"?`)) {
        return;
    }
    
    fetch(`/api/years/${selectedYearId}/document-due-dates/${encodeURIComponent(documentType)}`, {
        method: 'DELETE'
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showAlert(data.message, 'success');
            setTimeout(() => location.reload(), 1000);
        } else {
            showAlert(data.message || 'Failed to delete due date', 'danger');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('An error occurred while deleting the due date.', 'danger');
    });
}

function copyFromYear() {
    const sourceYearId = document.getElementById('copyFromYear').value;
    
    if (!sourceYearId) {
        showAlert('Please select a year to copy from.', 'warning');
        return;
    }
    
    if (!confirm('This will overwrite existing due dates. Are you sure?')) {
        return;
    }
    
    // First, get due dates from source year
    fetch(`/api/years/${sourceYearId}/document-due-dates`)
    .then(response => response.json())
    .then(data => {
        if (data.success && data.dueDates.length > 0) {
            // Copy each due date
            const promises = data.dueDates.map(dueDate => 
                fetch('/api/document-due-dates', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        yearId: selectedYearId,
                        documentType: dueDate.document_type,
                        dueDate: dueDate.due_date
                    })
                })
            );
            
            Promise.all(promises)
            .then(() => {
                showAlert('Due dates copied successfully!', 'success');
                setTimeout(() => location.reload(), 1000);
            })
            .catch(error => {
                console.error('Error copying due dates:', error);
                showAlert('Some due dates failed to copy.', 'warning');
            });
        } else {
            showAlert('No due dates found in the selected year.', 'warning');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('An error occurred while copying due dates.', 'danger');
    });
}

function clearAllDueDates() {
    if (!confirm('Are you sure you want to clear all due dates for this year? This cannot be undone.')) {
        return;
    }
    
    const documentTypes = [
        'Project Scribble', 'Project Order', 'Requirements Specification',
        'Thesis Assignment', 'Minutes', 'Worktime Report',
        'Thesis Document', 'Abstract', 'Monetary Benefit Description'
    ];
    
    const promises = documentTypes.map(docType => 
        fetch(`/api/years/${selectedYearId}/document-due-dates/${encodeURIComponent(docType)}`, {
            method: 'DELETE'
        })
    );
    
    Promise.all(promises)
    .then(() => {
        showAlert('All due dates cleared successfully!', 'success');
        setTimeout(() => location.reload(), 1000);
    })
    .catch(error => {
        console.error('Error clearing due dates:', error);
        showAlert('Some due dates failed to clear.', 'warning');
    });
}

function showAlert(message, type) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
    alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    document.body.insertBefore(alertDiv, document.body.firstChild);
    
    setTimeout(() => {
        if (alertDiv.parentNode) {
            alertDiv.parentNode.removeChild(alertDiv);
        }
    }, 5000);
}
</script>

<%- include('../partials/footer') %>