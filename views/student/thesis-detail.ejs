<%- include('../partials/header', { title: 'Diplomarbeit-Details - DABuddy', user: user }) %>

<%
const ROLE_LABELS = { student: 'Student', coach: 'Coach', expert: 'ExpertIn', admin: 'Administrator', department_lead: 'FachbereichsleiterIn', field_project_coach: 'Field Project Coach' };
const ACTION_LABELS = { document_upload: 'Dokument hochgeladen', document_update: 'Dokument aktualisiert', document_delete: 'Dokument gelöscht', evaluation_create: 'Bewertung erfasst', evaluation_update: 'Bewertung aktualisiert', milestone_approved: 'Meilenstein freigegeben', milestone_revoked: 'Freigabe zurückgezogen' };
const isAdmin = user.role === 'admin';
const fmtDateTime = (d) => new Date(d).toLocaleDateString('de-CH') + ' ' + new Date(d).toLocaleTimeString('de-CH', { hour: '2-digit', minute: '2-digit' });
%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Diplomarbeit-Details</li>
            </ol>
        </nav>
        <h1><%= thesis.title %></h1>
    </div>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Diplomjahr: <%= thesis.year.year %>
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-file-text"></i> Informationen zur Diplomarbeit</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Titel:</strong> <%= thesis.title %></p>
                        <p><strong>Fachbereich:</strong> <%= thesis.department.name %></p>
                        <% if (thesis.sponsor) { %>
                            <p><strong>Auftraggeber:</strong> <%= thesis.sponsor %></p>
                        <% } %>
                        <p><strong>Diplomjahr:</strong> <%= thesis.year.year %></p>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-4">
                        <h6><i class="bi bi-people"></i> Studenten:</h6>
                        <% if (thesis.students.length > 0) { %>
                            <% thesis.students.forEach(function(student) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary rounded-circle text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= student.firstname.charAt(0) %><%= student.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= student.firstname %> <%= student.name %></strong>
                                        <% if (student.id === user.id) { %><span class="badge bg-info ms-1">Sie</span><% } %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">Keine Studenten zugewiesen</p>
                        <% } %>
                    </div>
                    <div class="col-md-4">
                        <h6><i class="bi bi-person-badge"></i> Coaches:</h6>
                        <% if (thesis.coaches.length > 0) { %>
                            <% thesis.coaches.forEach(function(coach) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-success rounded-circle text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= coach.firstname.charAt(0) %><%= coach.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= coach.firstname %> <%= coach.name %></strong>
                                        <br><small class="text-muted"><%= coach.email %></small>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">Keine Coaches zugewiesen</p>
                        <% } %>
                    </div>
                    <div class="col-md-4 mt-3 mt-md-0">
                        <h6><i class="bi bi-person-workspace"></i> Field Project Coaches:</h6>
                        <% if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) { %>
                            <% thesis.fieldProjectCoaches.forEach(function(fpc) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-warning rounded-circle text-dark d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= fpc.firstname.charAt(0) %><%= fpc.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= fpc.firstname %> <%= fpc.name %></strong>
                                        <% if (fpc.id === user.id) { %><span class="badge bg-info ms-1">Sie</span><% } %>
                                        <br><small class="text-muted"><%= fpc.email %></small>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">Keine zugewiesen</p>
                        <% } %>
                    </div>
                    <div class="col-md-4 mt-3">
                        <h6><i class="bi bi-award"></i> ExpertInnen:</h6>
                        <% if (thesis.experts.length > 0) { %>
                            <% thesis.experts.forEach(function(expert) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-info rounded-circle text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= expert.firstname.charAt(0) %><%= expert.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= expert.firstname %> <%= expert.name %></strong>
                                        <br><small class="text-muted"><%= expert.email %></small>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">Keine ExpertInnen zugewiesen</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-flag"></i> Meilensteine</h5>
            </div>
            <div class="card-body">
                <% if (milestones.length === 0) { %>
                    <div class="text-center py-4">
                        <i class="bi bi-flag text-muted" style="font-size: 48px;"></i>
                        <p class="text-muted mt-2">Keine Meilensteine für diese Diplomarbeit.</p>
                    </div>
                <% } else { %>
                    <% milestones.forEach(function(m) { %>
                        <%
                        const docs = (m.documents || []).slice().sort((a, b) => b.version - a.version);
                        const hasDocs = docs.length > 0;
                        const currentDoc = docs.find(d => d.is_current) || (hasDocs ? docs[0] : null);
                        const isResponsible = (user.role === m.responsible_role) || isAdmin;
                        const showUpload = m.allow_upload && isResponsible && (!hasDocs || m.allow_update);
                        const canEvaluate = m.requires_evaluation && (user.role === m.evaluator_role || isAdmin);
                        const approvalSlots = [];
                        if (m.requires_approval) approvalSlots.push({ n: 1, role: m.approver_role, approvedAt: m.approved_at, approver: m.approver });
                        if (m.requires_approval_2) approvalSlots.push({ n: 2, role: m.approver_role_2, approvedAt: m.approved_at_2, approver: m.approver2 });
                        const allApproved = approvalSlots.length > 0 && approvalSlots.every(s => s.approvedAt);
                        const overdue = !hasDocs && new Date(m.due_at) < new Date();
                        %>
                        <div class="border rounded p-3 mb-3">
                            <div class="d-flex justify-content-between align-items-start flex-wrap">
                                <div>
                                    <h6 class="mb-1"><%= m.label %></h6>
                                    <div class="small">
                                        <span class="<%= overdue ? 'text-danger fw-bold' : 'text-muted' %>">
                                            <i class="bi bi-calendar-event"></i> <%= fmtDateTime(m.due_at) %>
                                            <% if (overdue) { %> (überfällig)<% } %>
                                        </span>
                                        <% if (isAdmin) { %>
                                            <button class="btn btn-sm btn-link p-0 ms-1" onclick='openOverrideDueAt(<%- JSON.stringify({ id: m.id, label: m.label, due_at: m.due_at }) %>)' title="Termin pro Diplomarbeit übersteuern">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                        <% } %>
                                        <span class="badge bg-secondary ms-2">Verantwortlich: <%= ROLE_LABELS[m.responsible_role] || m.responsible_role %></span>
                                        <% if (m.requires_evaluation) { %>
                                            <span class="badge bg-warning text-dark">Bewertung: <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %></span>
                                        <% } %>
                                    </div>
                                </div>
                                <div>
                                    <% if (showUpload) { %>
                                        <button class="btn btn-outline-primary btn-sm" onclick="openUploadModal(<%= m.id %>, '<%= m.label.replace(/'/g, "\\'") %>')">
                                            <i class="bi bi-upload"></i> <%= hasDocs ? 'Aktualisieren' : 'Hochladen' %>
                                        </button>
                                    <% } else if (!m.allow_upload) { %>
                                        <span class="text-muted small">Kein Upload vorgesehen</span>
                                    <% } else if (!hasDocs) { %>
                                        <span class="text-muted small">Wartet auf <%= ROLE_LABELS[m.responsible_role] || m.responsible_role %></span>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Dokumente (versioniert, alle behalten) -->
                            <% if (hasDocs) { %>
                                <div class="mt-3">
                                    <% docs.forEach(function(doc) { %>
                                        <div class="d-flex justify-content-between align-items-center border-top py-2">
                                            <div>
                                                <a href="/api/thesis-milestone-documents/<%= doc.id %>/download" class="text-decoration-none">
                                                    <i class="bi bi-file-earmark-pdf text-danger"></i> <%= doc.file_name %>
                                                </a>
                                                <% if (doc.is_current) { %>
                                                    <span class="badge bg-success ms-1">Aktuell · v<%= doc.version %></span>
                                                <% } else { %>
                                                    <span class="badge bg-secondary ms-1">Frühere Version · v<%= doc.version %></span>
                                                <% } %>
                                                <br>
                                                <small class="text-muted">
                                                    <%= formatFileSize(doc.file_size) %> · hochgeladen von
                                                    <%= doc.uploader ? (doc.uploader.firstname + ' ' + doc.uploader.name) : 'unbekannt' %>
                                                    am <%= fmtDateTime(doc.uploaded_at) %>
                                                    <% if (!doc.is_current && doc.superseded_at) { %>
                                                        · ersetzt am <%= fmtDateTime(doc.superseded_at) %>
                                                    <% } %>
                                                </small>
                                            </div>
                                            <% if (isAdmin) { %>
                                                <button class="btn btn-outline-danger btn-sm" onclick="deleteDocument(<%= doc.id %>)" title="Dokumentversion löschen (Admin)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="mt-2"><small class="text-muted"><i class="bi bi-dash-circle"></i> Noch kein Dokument hochgeladen.</small></div>
                            <% } %>

                            <!-- Bewertung -->
                            <% if (m.requires_evaluation) { %>
                                <div class="mt-3 bg-light rounded p-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <strong class="small">
                                            <i class="bi bi-star"></i> Bewertung
                                            <% if (m.evaluation_form_id) { %><span class="badge bg-primary ms-1">Formular</span><% } %>
                                            <span class="text-muted">· <%= ROLE_LABELS[m.evaluator_role] || m.evaluator_role %></span>
                                        </strong>
                                        <% if (m.evaluation_form_id) { %>
                                            <button class="btn btn-outline-secondary btn-sm" onclick="openEvaluationForm(<%= m.id %>, <%= canEvaluate ? 'true' : 'false' %>)">
                                                <i class="bi bi-clipboard-check"></i> Bewertung <%= canEvaluate ? 'ausfüllen' : 'ansehen' %>
                                            </button>
                                        <% } else if (canEvaluate) { %>
                                            <button class="btn btn-outline-secondary btn-sm" onclick='openEvalModal(<%- JSON.stringify({ id: m.id, label: m.label, evaluation: m.evaluation || "" }) %>)'>
                                                <i class="bi bi-pencil"></i> <%= m.evaluation ? 'Bewertung bearbeiten' : 'Bewerten' %>
                                            </button>
                                        <% } %>
                                    </div>
                                    <% if (m.evaluation_form_id) { %>
                                        <% if (m.thesisEvaluation && m.thesisEvaluation.overall_grade != null) { %>
                                            <div class="mt-2">
                                                Gesamtnote: <strong><%= Number(m.thesisEvaluation.overall_grade).toFixed(1) %></strong>
                                                <% (m.thesisEvaluation.groups || []).forEach(function(g) { %>
                                                    <% if (g.grade != null) { %>
                                                        <span class="badge bg-secondary ms-1" title="<%= g.name %>"><%= g.name %>: <%= Number(g.grade).toFixed(1) %></span>
                                                    <% } %>
                                                <% }); %>
                                                <br><small class="text-muted">
                                                    <%= m.thesisEvaluation.completed ? 'Abgeschlossen' : 'In Bearbeitung' %>
                                                    <% if (m.thesisEvaluation.evaluator) { %> · von <%= m.thesisEvaluation.evaluator.firstname %> <%= m.thesisEvaluation.evaluator.name %><% } %>
                                                    <% if (m.thesisEvaluation.evaluated_at) { %> am <%= fmtDateTime(m.thesisEvaluation.evaluated_at) %><% } %>
                                                </small>
                                            </div>
                                        <% } else { %>
                                            <div class="mt-1"><small class="text-muted">Noch keine Bewertung erfasst.</small></div>
                                        <% } %>
                                    <% } else { %>
                                        <% if (m.evaluation) { %>
                                            <div class="mt-2" style="white-space: pre-wrap;"><%= m.evaluation %></div>
                                            <small class="text-muted">
                                                <%= m.evaluator ? ('von ' + m.evaluator.firstname + ' ' + m.evaluator.name) : '' %>
                                                <% if (m.evaluated_at) { %> am <%= fmtDateTime(m.evaluated_at) %><% } %>
                                            </small>
                                        <% } else { %>
                                            <div class="mt-1"><small class="text-muted">Noch keine Bewertung erfasst.</small></div>
                                        <% } %>
                                    <% } %>
                                </div>
                            <% } %>

                            <!-- Freigaben -->
                            <% if (approvalSlots.length > 0) { %>
                                <div class="mt-3 border rounded p-2 <%= allApproved ? 'border-success' : '' %>">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <strong class="small"><i class="bi bi-unlock"></i> Freigaben</strong>
                                        <% if (allApproved) { %><span class="badge bg-success"><i class="bi bi-check-circle"></i> Vollständig freigegeben</span><% } %>
                                    </div>
                                    <% approvalSlots.forEach(function(s) { %>
                                        <% const canApproveSlot = (user.role === s.role) || isAdmin; %>
                                        <div class="d-flex justify-content-between align-items-center py-1 small">
                                            <div>
                                                <strong>Freigabe <%= s.n %></strong>
                                                <span class="text-muted">· <%= ROLE_LABELS[s.role] || s.role %></span>
                                                <% if (s.approvedAt) { %>
                                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Freigegeben</span>
                                                    <span class="text-muted">
                                                        <% if (s.approver) { %>von <%= s.approver.firstname %> <%= s.approver.name %><% } %>
                                                        am <%= fmtDateTime(s.approvedAt) %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-warning text-dark">offen</span>
                                                <% } %>
                                            </div>
                                            <% if (canApproveSlot) { %>
                                                <div>
                                                    <% if (!s.approvedAt) { %>
                                                        <button class="btn btn-success btn-sm" onclick="setApproval(<%= m.id %>, <%= s.n %>, true)"><i class="bi bi-check-lg"></i> Freigeben</button>
                                                    <% } else { %>
                                                        <button class="btn btn-outline-danger btn-sm" onclick="setApproval(<%= m.id %>, <%= s.n %>, false)"><i class="bi bi-x-lg"></i> Zurückziehen</button>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>

        <!-- Änderungsprotokoll -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-clock-history"></i> Änderungsprotokoll</h5>
            </div>
            <div class="card-body">
                <% if (!logs || logs.length === 0) { %>
                    <p class="text-muted mb-0">Noch keine Änderungen protokolliert.</p>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Zeitstempel</th>
                                    <th>Benutzer</th>
                                    <th>Aktion</th>
                                    <th>Detail</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% logs.forEach(function(log) { %>
                                    <tr>
                                        <td class="text-nowrap"><small><%= fmtDateTime(log.createdAt) %></small></td>
                                        <td><small><%= log.user ? (log.user.firstname + ' ' + log.user.name) : 'unbekannt' %></small></td>
                                        <td><small><%= ACTION_LABELS[log.action] || log.action %></small></td>
                                        <td><small class="text-muted"><%= log.detail || '' %></small></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dokument hochladen — <span id="uploadModalLabel"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="uploadForm" enctype="multipart/form-data">
                <div class="modal-body">
                    <input type="hidden" id="uploadMilestoneId">
                    <div class="mb-3">
                        <label class="form-label">PDF-Datei</label>
                        <input type="file" class="form-control" name="document" accept=".pdf" required>
                        <div class="form-text">Maximale Dateigrösse: 50 MB. Nur PDF-Dateien. Frühere Versionen bleiben erhalten.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Hochladen</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Bewertungs-Modal (Freitext) -->
<div class="modal fade" id="evalModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Bewertung — <span id="evalModalLabel"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="evalForm">
                <div class="modal-body">
                    <input type="hidden" id="evalMilestoneId">
                    <div class="mb-3">
                        <label class="form-label">Bewertung</label>
                        <textarea class="form-control" id="evalText" name="evaluation" rows="6"></textarea>
                        <div class="form-text">Freitext-Bewertung.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.score-circles { display: flex; gap: .35rem; flex-wrap: wrap; }
.score-circle {
    width: 40px; height: 40px; border-radius: 50%;
    border: 2px solid #6c757d; background: #fff; color: #495057;
    font-weight: 600; line-height: 1; display: inline-flex;
    align-items: center; justify-content: center; padding: 0;
}
.score-circle.active { background: #0d6efd; border-color: #0d6efd; color: #fff; }
.score-circle:not(:disabled) { cursor: pointer; }
.score-circle:disabled { opacity: .6; cursor: default; }
</style>

<!-- Bewertungs-Modal (Formular) -->
<div class="modal fade" id="evalFormModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="evalFormTitle">Bewertung</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="evalFormBody"><p class="text-muted">Wird geladen…</p></div>
            </div>
            <div class="modal-footer">
                <div class="me-auto" id="evalFormOverall"></div>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Schliessen</button>
                <button type="button" class="btn btn-primary" id="evalFormSaveBtn" onclick="saveEvaluationForm()">Speichern</button>
            </div>
        </div>
    </div>
</div>

<% if (isAdmin) { %>
<!-- Override Termin Modal -->
<div class="modal fade" id="overrideModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Termin übersteuern — <span id="overrideLabel"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="overrideForm">
                <div class="modal-body">
                    <input type="hidden" id="overrideMilestoneId">
                    <div class="mb-3">
                        <label class="form-label">Neuer Termin (Datum & Zeit)</label>
                        <input type="datetime-local" class="form-control" id="overrideDueAt" required>
                    </div>
                    <p class="text-muted small">Diese Änderung gilt nur für diese Diplomarbeit.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Speichern</button>
                </div>
            </form>
        </div>
    </div>
</div>
<% } %>

<script>
function toLocalInput(iso) {
    const d = new Date(iso);
    const pad = n => String(n).padStart(2, '0');
    return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
}

function openUploadModal(id, label) {
    document.getElementById('uploadMilestoneId').value = id;
    document.getElementById('uploadModalLabel').textContent = label;
    document.getElementById('uploadForm').reset();
    new bootstrap.Modal(document.getElementById('uploadModal')).show();
}

document.getElementById('uploadForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const id = document.getElementById('uploadMilestoneId').value;
    const formData = new FormData(this);

    const btn = this.querySelector('button[type="submit"]');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Wird hochgeladen...';

    fetch(`/api/thesis-milestones/${id}/document`, { method: 'POST', body: formData })
        .then(r => r.json())
        .then(d => {
            if (d.success) location.reload();
            else alert('Fehler: ' + (d.message || 'Unbekannt'));
        })
        .catch(err => { console.error(err); alert('Fehler beim Hochladen'); })
        .finally(() => { btn.disabled = false; btn.innerHTML = orig; });
});

function openEvalModal(m) {
    document.getElementById('evalMilestoneId').value = m.id;
    document.getElementById('evalModalLabel').textContent = m.label;
    document.getElementById('evalText').value = m.evaluation || '';
    new bootstrap.Modal(document.getElementById('evalModal')).show();
}

document.getElementById('evalForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const id = document.getElementById('evalMilestoneId').value;
    const evaluation = document.getElementById('evalText').value;

    fetch(`/api/thesis-milestones/${id}/evaluation`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ evaluation })
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) location.reload();
        else alert('Fehler: ' + (d.message || 'Unbekannt'));
    })
    .catch(err => { console.error(err); alert('Fehler beim Speichern der Bewertung'); });
});

// ---- Freigabe ----
function setApproval(tmId, slot, approved) {
    const msg = approved ? ('Freigabe ' + slot + ' erteilen?') : ('Freigabe ' + slot + ' wirklich zurückziehen?');
    if (!confirm(msg)) return;
    fetch(`/api/thesis-milestones/${tmId}/approval`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slot, approved })
    })
    .then(r => r.json())
    .then(d => { if (d.success) location.reload(); else alert('Fehler: ' + (d.message || 'Unbekannt')); })
    .catch(e => { console.error(e); alert('Fehler bei der Freigabe'); });
}

// ---- Strukturiertes Bewertungsformular ----
let evalFormState = { tmId: null, editable: false, evaluation: null };

function escapeHtml(s){ return (s||'').replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c])); }
function roundTenth(x){ return Math.round(x*10)/10; }

function openEvaluationForm(tmId, editable) {
    evalFormState = { tmId, editable, evaluation: null };
    document.getElementById('evalFormBody').innerHTML = '<p class="text-muted">Wird geladen…</p>';
    document.getElementById('evalFormOverall').innerHTML = '';
    document.getElementById('evalFormSaveBtn').classList.toggle('d-none', !editable);
    new bootstrap.Modal(document.getElementById('evalFormModal')).show();

    fetch(`/api/thesis-milestones/${tmId}/evaluation-form`)
        .then(r => r.json())
        .then(d => {
            if (!d.success) { document.getElementById('evalFormBody').innerHTML = '<div class="alert alert-danger">'+(d.message||'Fehler')+'</div>'; return; }
            if (!d.hasForm) { document.getElementById('evalFormBody').innerHTML = '<div class="alert alert-info">Kein Formular zugewiesen.</div>'; return; }
            if (!d.started) { document.getElementById('evalFormBody').innerHTML = '<div class="alert alert-info">Die Bewertung wurde noch nicht gestartet (nur die bewertende Rolle kann sie starten).</div>'; return; }
            evalFormState.evaluation = d.evaluation;
            renderEvaluationForm();
        })
        .catch(e => { console.error(e); document.getElementById('evalFormBody').innerHTML = '<div class="alert alert-danger">Fehler beim Laden</div>'; });
}

function renderEvaluationForm() {
    const ev = evalFormState.evaluation;
    const editable = evalFormState.editable;
    const groups = (ev.groups || []).slice().sort((a,b)=>a.position-b.position);
    document.getElementById('evalFormTitle').textContent = 'Bewertung — ' + ev.form_title;

    let html = '';
    groups.forEach(g => {
        const crits = (g.criteria || []).slice().sort((a,b)=>a.position-b.position);
        html += `<div class="card mb-3"><div class="card-header d-flex justify-content-between">
            <strong>${escapeHtml(g.name)}</strong>
            <span><span class="badge bg-secondary">Gewicht ${g.weight}</span> <span class="badge bg-info text-dark" id="grp-grade-${g.id}">Note —</span></span>
        </div><div class="card-body">`;
        crits.forEach(c => {
            const levels = c.level_descriptions || [];
            let circles = '';
            for (let i=0;i<=5;i++){
                const tip = (levels[i] && levels[i].trim()) ? levels[i] : ('Stufe ' + i);
                circles += `<button type="button" class="score-circle ${String(c.score)===String(i)?'active':''}" data-score="${i}"
                    data-bs-toggle="tooltip" data-bs-placement="top" title="${escapeHtml(tip)}" ${editable?'':'disabled'}>${i}</button>`;
            }
            const remarkBlock = editable
                ? `<textarea class="form-control form-control-sm crit-remark" rows="3" placeholder="Bemerkung (Markdown, Leerzeile = neuer Absatz)">${escapeHtml(c.remark||'')}</textarea>`
                : (c.remark ? `<div class="border rounded p-2 bg-white">${renderMarkdownBlock(c.remark)}</div>` : '<span class="text-muted small">—</span>');
            html += `<div class="mb-3 border-bottom pb-3" data-crit="${c.id}" data-weight="${c.weight}" data-group="${g.id}">
                <div class="fw-semibold">${renderMarkdownBlock(c.label)}</div>
                <span class="text-muted small">Gewicht ${c.weight}, max. ${(5*Number(c.weight)).toFixed(1)} Pkt.</span>
                <div class="mt-2">
                    <label class="form-label small mb-1">Punkte (0–5) — auf einen Kreis fahren für die Beschreibung</label>
                    <div class="score-circles">
                        <input type="hidden" class="crit-score" value="${(c.score===null||c.score===undefined)?'':c.score}">
                        ${circles}
                    </div>
                    <div class="small text-muted mt-1 crit-leveldesc"></div>
                </div>
                <div class="mt-2">
                    <label class="form-label small mb-1">Bemerkung <span class="text-muted">(Markdown)</span></label>
                    ${remarkBlock}
                </div>
            </div>`;
        });
        html += `</div></div>`;
    });
    document.getElementById('evalFormBody').innerHTML = html;

    // Level description display, circle selection, live grade recompute
    document.querySelectorAll('#evalFormBody [data-crit]').forEach(row => {
        updateLevelDesc(row);
        row.querySelectorAll('.score-circle:not(:disabled)').forEach(btn => {
            btn.addEventListener('click', () => {
                row.querySelector('.crit-score').value = btn.getAttribute('data-score');
                row.querySelectorAll('.score-circle').forEach(b => b.classList.toggle('active', b === btn));
                updateLevelDesc(row);
                recomputeGrades();
            });
        });
    });

    // Bootstrap-Tooltips initialisieren
    document.querySelectorAll('#evalFormBody [data-bs-toggle="tooltip"]').forEach(el => {
        try { new bootstrap.Tooltip(el); } catch (e) {}
    });

    recomputeGrades();
}

function updateLevelDesc(row) {
    const crit = findCriterion(row.getAttribute('data-crit'));
    const v = row.querySelector('.crit-score').value;
    const desc = row.querySelector('.crit-leveldesc');
    if (!desc) return;
    desc.textContent = (v === '') ? '' : ('Stufe ' + v + ': ' + ((crit.level_descriptions||[])[Number(v)] || ''));
}

function findCriterion(critId) {
    for (const g of evalFormState.evaluation.groups) {
        for (const c of g.criteria) { if (String(c.id) === String(critId)) return c; }
    }
    return null;
}

function recomputeGrades() {
    const groups = evalFormState.evaluation.groups || [];
    let weightedSum = 0, weightTotal = 0;
    groups.forEach(g => {
        let achieved = 0, max = 0, scored = 0;
        (g.criteria||[]).forEach(c => {
            const row = document.querySelector(`#evalFormBody [data-crit="${c.id}"]`);
            if (!row) return;
            const val = row.querySelector('.crit-score').value;
            if (val === '') return;
            const w = Number(c.weight)||0;
            achieved += Number(val)*w; max += 5*w; scored++;
        });
        const badge = document.getElementById('grp-grade-'+g.id);
        if (scored === 0 || max === 0) { if (badge) badge.textContent = 'Note —'; return; }
        const grade = roundTenth(achieved/max*5+1);
        if (badge) badge.textContent = 'Note ' + grade.toFixed(1);
        weightedSum += grade*(Number(g.weight)||0); weightTotal += (Number(g.weight)||0);
    });
    const overallEl = document.getElementById('evalFormOverall');
    if (weightTotal > 0) overallEl.innerHTML = '<strong>Gesamtnote (Vorschau): ' + roundTenth(weightedSum/weightTotal).toFixed(1) + '</strong>';
    else overallEl.innerHTML = '';
}

function saveEvaluationForm() {
    const rows = document.querySelectorAll('#evalFormBody [data-crit]');
    const criteria = [];
    let validationError = null;
    rows.forEach(row => {
        const id = Number(row.getAttribute('data-crit'));
        const val = row.querySelector('.crit-score').value;
        const remarkEl = row.querySelector('.crit-remark');
        const remark = remarkEl ? remarkEl.value : '';
        const score = (val === '') ? null : Number(val);
        if (score !== null && score < 3 && remark.trim().length < 10) {
            const crit = findCriterion(id);
            const label = crit ? crit.label.replace(/[#*_`>\-]/g, '').trim() : '';
            validationError = 'Bei "' + label + '" ist bei einer Bewertung unter 3 eine Bemerkung von mindestens 10 Zeichen erforderlich.';
        }
        criteria.push({ id, score, remark });
    });
    if (validationError) { alert(validationError); return; }

    const btn = document.getElementById('evalFormSaveBtn');
    btn.disabled = true;
    fetch(`/api/thesis-milestones/${evalFormState.tmId}/evaluation-form`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ criteria })
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) location.reload();
        else { alert('Fehler: ' + (d.message || 'Unbekannt')); btn.disabled = false; }
    })
    .catch(e => { console.error(e); alert('Fehler beim Speichern'); btn.disabled = false; });
}

