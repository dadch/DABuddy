<%- include('../partials/header', { title: 'Studenten-Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Meine Diplomarbeit</h1>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear %>
    </div>
</div>

<% if (theses.length === 0) { %>
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        Für das ausgewählte Diplomjahr wurde keine Diplomarbeit gefunden. Bitte kontaktieren Sie Ihre Koordination.
    </div>
<% } else { %>
    <% theses.forEach(function(thesis) { %>
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-file-text"></i> <%= thesis.title %>
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Fachbereich:</strong> <%= thesis.department.name %></p>
                        <% if (thesis.sponsor) { %>
                            <p><strong>Auftraggeber:</strong> <%= thesis.sponsor %></p>
                        <% } %>
                        <p><strong>Diplomjahr:</strong> <%= thesis.year.year %></p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary">
                            <i class="bi bi-eye"></i> Details & Meilensteine
                        </a>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-4">
                        <h6><i class="bi bi-people"></i> Studenten:</h6>
                        <% thesis.students.forEach(function(s) { %>
                            <div class="mb-2"><i class="bi bi-person-fill"></i> <%= s.firstname %> <%= s.name %><% if (s.id === user.id) { %> <span class="badge bg-info ms-1">Sie</span><% } %></div>
                        <% }); %>
                    </div>
                    <div class="col-md-4">
                        <h6><i class="bi bi-person-badge"></i> Coaches:</h6>
                        <% thesis.coaches.forEach(function(c) { %>
                            <div class="mb-2"><i class="bi bi-person-fill"></i> <%= c.firstname %> <%= c.name %></div>
                        <% }); %>
                    </div>
                    <div class="col-md-4">
                        <h6><i class="bi bi-award"></i> ExpertInnen:</h6>
                        <% thesis.experts.forEach(function(e) { %>
                            <div class="mb-2"><i class="bi bi-person-fill"></i> <%= e.firstname %> <%= e.name %></div>
                        <% }); %>
                    </div>
                    <% if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) { %>
                    <div class="col-md-4 mt-3">
                        <h6><i class="bi bi-person-workspace"></i> Field Project Coaches:</h6>
                        <% thesis.fieldProjectCoaches.forEach(function(f) { %>
                            <div class="mb-2"><i class="bi bi-person-fill"></i> <%= f.firstname %> <%= f.name %></div>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    <% }); %>
<% } %>

<%- include('../partials/footer') %>
