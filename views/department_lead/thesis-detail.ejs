<%- include('../partials/header', { title: 'Thesis Details - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
                <li class="breadcrumb-item active" aria-current="page">Thesis Details</li>
            </ol>
        </nav>
        <h1><%= thesis.title %></h1>
    </div>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Academic Year: <%= thesis.year.year %>
    </div>
</div>

<div class="row">
    <!-- Main Content -->
    <div class="col-lg-8">
        <!-- Thesis Information -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-file-text"></i> Thesis Information
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <p><strong>Title:</strong> <%= thesis.title %></p>
                        <p><strong>Department:</strong> <%= thesis.department.name %></p>
                        <% if (thesis.sponsor) { %>
                            <p><strong>Sponsor:</strong> <%= thesis.sponsor %></p>
                        <% } %>
                        <p><strong>Academic Year:</strong> <%= thesis.year.year %></p>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <strong>Current State:</strong>
                            <div class="mt-1">
                                <span class="badge bg-<%= getStateColor(thesis.state) %> me-2">
                                    <i class="bi bi-circle-fill"></i> <%= thesis.state %>
                                </span>
                                <button class="btn btn-outline-info btn-sm" onclick="changeThesisState(<%= thesis.id %>)" title="Change State">
                                    <i class="bi bi-arrow-repeat"></i> Change State
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Team Members -->
                <div class="row mt-4">
                    <div class="col-md-4">
                        <h6><i class="bi bi-people"></i> Students:</h6>
                        <% if (thesis.students.length > 0) { %>
                            <% thesis.students.forEach(function(student) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-primary rounded-circle text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= student.firstname.charAt(0) %><%= student.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= student.firstname %> <%= student.name %></strong>
                                        <% if (student.id === user.id) { %>
                                            <span class="badge bg-info ms-1">You</span>
                                        <% } %>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">No students assigned</p>
                        <% } %>
                    </div>
                    <div class="col-md-4">
                        <h6><i class="bi bi-person-badge"></i> Coaches:</h6>
                        <% if (thesis.coaches.length > 0) { %>
                            <% thesis.coaches.forEach(function(coach) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-success rounded-circle text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= coach.firstname.charAt(0) %><%= coach.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= coach.firstname %> <%= coach.name %></strong>
                                        <br><small class="text-muted"><%= coach.email %></small>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">No coaches assigned</p>
                        <% } %>
                    </div>
                    <div class="col-md-4">
                        <h6><i class="bi bi-award"></i> Experts:</h6>
                        <% if (thesis.experts.length > 0) { %>
                            <% thesis.experts.forEach(function(expert) { %>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="bg-info rounded-circle text-white d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 14px;">
                                        <%= expert.firstname.charAt(0) %><%= expert.name.charAt(0) %>
                                    </div>
                                    <div>
                                        <strong><%= expert.firstname %> <%= expert.name %></strong>
                                        <br><small class="text-muted"><%= expert.email %></small>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-muted">No experts assigned</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Document Upload Section -->
        <% if (uploadableDocuments.length > 0) { %>
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-cloud-upload"></i> Upload Documents
                    </h5>
                </div>
                <div class="card-body">
                    <form id="uploadForm" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="documentType" class="form-label">Document Type</label>
                                    <select class="form-select" id="documentType" name="document_type" required>
                                        <option value="">Select document type...</option>
                                        <% uploadableDocuments.forEach(function(docType) { %>
                                            <option value="<%= docType %>"><%= docType %></option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="documentFile" class="form-label">PDF File</label>
                                    <input type="file" class="form-control" id="documentFile" name="document" accept=".pdf" required>
                                    <div class="form-text">Maximum file size: 50MB. Only PDF files are allowed.</div>
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload"></i> Upload Document
                        </button>
                    </form>
                </div>
            </div>
        <% } %>

        <!-- Documents List -->
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-files"></i> Documents
                </h5>
            </div>
            <div class="card-body">
                <% if (documents.length === 0) { %>
                    <div class="text-center py-4">
                        <i class="bi bi-file-earmark text-muted" style="font-size: 48px;"></i>
                        <p class="text-muted mt-2">No documents uploaded yet.</p>
                    </div>
                <% } else { %>
                    <% displayableDocuments.forEach(function(docType) { %>
                        <% const docsOfType = documentsByType[docType] || []; %>
                        <div class="document-type-section mb-4">
                            <h6 class="text-primary">
                                <i class="bi bi-file-earmark-pdf"></i> <%= docType %>
                                <% if (requiredDocuments.includes(docType)) { %>
                                    <span class="badge bg-danger ms-2">Required</span>
                                <% } %>
                            </h6>
                            <% if (docsOfType.length === 0) { %>
                                <div class="alert alert-light py-2">
                                    <small class="text-muted">No documents of this type uploaded.</small>
                                </div>
                            <% } else { %>
                                <% docsOfType.forEach(function(doc) { %>
                                    <div class="document-item border rounded p-3 mb-2">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div>
                                                <h6 class="mb-1"><%= doc.name %></h6>
                                                <small class="text-muted">
                                                    Uploaded by <%= doc.uploader.firstname %> <%= doc.uploader.name %>
                                                    on <%= new Date(doc.upload_timestamp).toLocaleDateString() %>
                                                    at <%= new Date(doc.upload_timestamp).toLocaleTimeString() %>
                                                </small>
                                                <div class="mt-1">
                                                    <small class="text-muted">Size: <%= formatFileSize(doc.size) %></small>
                                                    <% if (dueDateMap[doc.document_type]) { %>
                                                        <br><small class="text-muted">Due: <%= new Date(dueDateMap[doc.document_type]).toLocaleDateString() %></small>
                                                    <% } %>
                                                </div>
                                            </div>
                                            <div class="btn-group">
                                                <a href="/api/documents/<%= doc.id %>/download" class="btn btn-outline-primary btn-sm" title="Download">
                                                    <i class="bi bi-download"></i>
                                                </a>
                                                <% if (doc.uploaded_by === user.id || user.role === 'admin') { %>
                                                    <button class="btn btn-outline-danger btn-sm" onclick="deleteDocument(<%= doc.id %>)" title="Delete">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }); %>
                            <% } %>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="col-lg-4">
        <!-- Document Requirements -->
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-list-check"></i> Document Requirements
                </h6>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <strong>Current State:</strong> <%= thesis.state %>
                </div>
                <% if (requiredDocuments.length > 0) { %>
                    <div class="mb-3">
                        <strong>Required Documents:</strong>
                        <ul class="list-unstyled mt-2">
                            <% requiredDocuments.forEach(function(docType) { %>
                                <li class="mb-1">
                                    <% if (documentsByType[docType] && documentsByType[docType].length > 0) { %>
                                        <i class="bi bi-check-circle text-success"></i>
                                    <% } else { %>
                                        <i class="bi bi-x-circle text-danger"></i>
                                    <% } %>
                                    <%= docType %>
                                </li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>
                <% if (displayableDocuments.length > 0) { %>
                    <div class="mb-3">
                        <strong>All Document Types:</strong>
                        <ul class="list-unstyled mt-2">
                            <% displayableDocuments.forEach(function(docType) { %>
                                <li class="mb-1">
                                    <i class="bi bi-file-earmark-pdf text-primary"></i> <%= docType %>
                                </li>
                            <% }); %>
                        </ul>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="bi bi-activity"></i> Recent Activity
                </h6>
            </div>
            <div class="card-body">
                <% if (documentLogs.length === 0) { %>
                    <div class="text-center py-3">
                        <i class="bi bi-clock text-muted" style="font-size: 24px;"></i>
                        <p class="text-muted mt-2 mb-0">No recent activity.</p>
                    </div>
                <% } else { %>
                    <% documentLogs.forEach(function(log) { %>
                        <div class="activity-item mb-3">
                            <div class="d-flex align-items-start">
                                <div class="activity-icon me-2">
                                    <% if (log.action === 'upload') { %>
                                        <i class="bi bi-upload text-success"></i>
                                    <% } else if (log.action === 'delete') { %>
                                        <i class="bi bi-trash text-danger"></i>
                                    <% } else { %>
                                        <i class="bi bi-file-earmark text-primary"></i>
                                    <% } %>
                                </div>
                                <div class="activity-content">
                                    <div class="activity-text">
                                        <strong><%= log.user.firstname %> <%= log.user.name %></strong>
                                        <%= log.action %>ed "<%= log.document_name %>"
                                    </div>
                                    <div class="activity-time text-muted">
                                        <small><%= new Date(log.upload_timestamp).toLocaleDateString() %> at <%= new Date(log.upload_timestamp).toLocaleTimeString() %></small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Change State Modal -->
<div class="modal fade" id="changeStateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Change Thesis State</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="changeStateForm">
                <div class="modal-body">
                    <input type="hidden" id="stateThesisId" name="thesisId">
                    <div class="mb-3">
                        <label for="currentState" class="form-label">Current State</label>
                        <input type="text" class="form-control" id="currentState" readonly>
                    </div>
                    <div class="mb-3">
                        <label for="newState" class="form-label">New State</label>
                        <select class="form-select" id="newState" name="newState" required>
                            <option value="">Select new state...</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Change State</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
// Document upload functionality
document.getElementById('uploadForm')?.addEventListener('submit', function(e) {
    e.preventDefault();
    
    const formData = new FormData(this);
    const submitBtn = this.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="bi bi-spinner spinner-border spinner-border-sm"></i> Uploading...';
    
    fetch(`/api/theses/<%= thesis.id %>/documents`, {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        } else {
            alert('Error uploading document: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error uploading document:', error);
        alert('Error uploading document');
    })
    .finally(() => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
    });
});

// Delete document functionality
function deleteDocument(documentId) {
    if (confirm('Are you sure you want to delete this document?')) {
        fetch(`/api/documents/${documentId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error deleting document: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error deleting document:', error);
            alert('Error deleting document');
        });
    }
}

// State change functionality
function changeThesisState(thesisId) {
    fetch(`/api/theses/${thesisId}/state-options`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('stateThesisId').value = thesisId;
                document.getElementById('currentState').value = data.currentState;
                
                const newStateSelect = document.getElementById('newState');
                newStateSelect.innerHTML = '<option value="">Select new state...</option>';
                
                data.availableStates.forEach(state => {
                    const option = document.createElement('option');
                    option.value = state.value;
                    option.textContent = state.label;
                    newStateSelect.appendChild(option);
                });
                
                new bootstrap.Modal(document.getElementById('changeStateModal')).show();
            } else {
                alert('Error loading state options: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error loading state options:', error);
            alert('Error loading state options');
        });
}

document.getElementById('changeStateForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const thesisId = formData.get('thesisId');
    const newState = formData.get('newState');
    
    fetch(`/api/theses/${thesisId}/state`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ newState })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('changeStateModal')).hide();
            location.reload();
        } else {
            alert('Error changing state: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error changing state:', error);
        alert('Error changing state');
    });
});
</script>

<%- include('../partials/footer') %>