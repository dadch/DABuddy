<%- include('../partials/header', { title: 'FachbereichsleiterIn-Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Fachbereichsverwaltung</h1>
    <div class="d-flex align-items-center gap-3">
        <%- include('../partials/year-switcher', { availableYears: availableYears, selectedYearId: selectedYearId }) %>
        <%- include('../partials/role-switcher', { availableRoles: availableRoles, currentRole: currentRole }) %>
        <div class="dropdown">
            <button class="btn btn-primary" type="button" id="dashboardActionsMenu" data-bs-toggle="dropdown" aria-expanded="false" title="Aktionen">
                <i class="bi bi-three-dots-vertical"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dashboardActionsMenu">
                <li><button class="dropdown-item" type="button" onclick="openAddThesisModal()"><i class="bi bi-plus"></i> Diplomarbeit hinzufügen</button></li>
                <li><hr class="dropdown-divider"></li>
                <li><button class="dropdown-item" type="button" onclick="openUserManagementModal()"><i class="bi bi-person-gear"></i> Benutzer verwalten</button></li>
                <li><button class="dropdown-item" type="button" onclick="openStudentManagement()"><i class="bi bi-mortarboard"></i> Studierende verwalten</button></li>
            </ul>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-mortarboard"></i> Diplomarbeiten im Fachbereich
                </h5>
                <h3 class="text-primary"><%= theses.length %></h3>
            </div>
        </div>
    </div>
</div>

<% if (departments.length > 1) { %>
<div class="row mb-3">
    <div class="col-md-4">
        <form method="GET" action="/dashboard" class="d-flex">
            <select name="department" class="form-select me-2" onchange="this.form.submit()">
                <option value="">Alle meine Fachbereiche</option>
                <% departments.forEach(function(dept) { %>
                    <option value="<%= dept.id %>" <%= selectedDepartment == dept.id ? 'selected' : '' %>>
                        <%= dept.name %>
                    </option>
                <% }); %>
            </select>
        </form>
    </div>
</div>
<% } %>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5>Diplomarbeiten im Fachbereich</h5>
            </div>
            <div class="card-body">
                <% if (theses.length === 0) { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Für Ihre Fachbereiche wurden keine Diplomarbeiten gefunden.
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Titel der Diplomarbeit</th>
                                    <th>Fachbereich</th>
                                    <th>Studenten</th>
                                    <th>Dozent/innen</th>
                                    <th>Field Project Coaches</th>
                                    <th>Experten</th>
                                    <th>Auftraggeber</th>
                                    <th>Aktionen</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% theses.forEach(function(thesis) { %>
                                    <tr>
                                        <td>
                                            <strong><%= thesis.title %></strong>
                                        </td>
                                        <td><%= thesis.department.name %></td>
                                        <td>
                                            <% if (thesis.students.length > 0) { %>
                                                <% thesis.students.forEach(function(student, index) { %>
                                                    <span class="badge bg-primary me-1"><%= student.name %>, <%= student.firstname %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">Keine Studenten zugewiesen</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (thesis.coaches.length > 0) { %>
                                                <% thesis.coaches.forEach(function(coach, index) { %>
                                                    <span class="badge bg-success me-1"><%= coach.name %>, <%= coach.firstname %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">Keine Dozent/innen zugewiesen</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) { %>
                                                <% thesis.fieldProjectCoaches.forEach(function(fpc, index) { %>
                                                    <span class="badge bg-warning text-dark me-1"><%= fpc.name %>, <%= fpc.firstname %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">Keine zugewiesen</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (thesis.experts.length > 0) { %>
                                                <% thesis.experts.forEach(function(expert, index) { %>
                                                    <span class="badge bg-info me-1"><%= expert.name %>, <%= expert.firstname %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">Keine Experten zugewiesen</span>
                                            <% } %>
                                        </td>
                                        <td><%= thesis.sponsor || '-' %></td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="editThesis(<%= thesis.id %>)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteThesis(<%= thesis.id %>)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Diplomarbeit hinzufügen Modal -->
<div class="modal fade" id="addThesisModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Neue Diplomarbeit hinzufügen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addThesisForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="thesisTitle" class="form-label">Titel</label>
                        <input type="text" class="form-control" id="thesisTitle" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label for="thesisDepartment" class="form-label">Fachbereich</label>
                        <select class="form-select" id="thesisDepartment" name="department_id" required>
                            <option value="">Fachbereich auswählen</option>
                            <% departments.forEach(function(dept) { %>
                                <option value="<%= dept.id %>"><%= dept.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisSponsor" class="form-label">Auftraggeber (optional)</label>
                        <input type="text" class="form-control" id="thesisSponsor" name="sponsor">
                    </div>
                    <div class="mb-3">
                        <label for="thesisLanguage" class="form-label">Sprache der Diplomarbeit</label>
                        <select class="form-select" id="thesisLanguage" name="language">
                            <option value="de">Deutsch</option>
                            <option value="fr">Französisch</option>
                        </select>
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="thesisIsConfidential" name="is_confidential">
                        <label class="form-check-label" for="thesisIsConfidential">
                            <i class="bi bi-lock"></i> Geheimhaltung (vertrauliche Diplomarbeit)
                        </label>
                    </div>
                    <div class="mb-3">
                        <label for="thesisStudents" class="form-label">Studenten (max. 1-2)</label>
                        <select class="form-select" id="thesisStudents" name="students" multiple size="4">
                            <option value="">Studenten auswählen...</option>
                        </select>
                        <div class="form-text">Strg/Cmd halten, um mehrere Studenten auszuwählen (maximal 2)</div>
                    </div>
                    <div class="mb-3">
                        <label for="thesisCoach" class="form-label">Dozent/in</label>
                        <select class="form-select" id="thesisCoach" name="coach">
                            <option value="">Dozent/in auswählen...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisFieldProjectCoach" class="form-label">Field Project Coach</label>
                        <select class="form-select" id="thesisFieldProjectCoach" name="field_project_coach">
                            <option value="">Field Project Dozent/in auswählen...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisExpert" class="form-label">ExpertIn</label>
                        <select class="form-select" id="thesisExpert" name="expert">
                            <option value="">ExpertIn auswählen...</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                    <button type="submit" class="btn btn-primary">Diplomarbeit hinzufügen</button>
                </div>
            </form>
        </div>
    </div>
</div>

