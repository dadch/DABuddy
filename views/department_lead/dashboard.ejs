// Add department change handlers for thesis forms
document.getElementById('thesisDepartment').addEventListener('change', function() {
    const departmentId = this.value;
    if (departmentId) {
        loadUserOptions(departmentId);
    } else {
        loadUserOptions(); // Load all users if no department selected
    }
});

document.getElementById('editThesisDepartment').addEventListener('change', function() {
    const departmentId = this.value;
    
    // Check if there are current selections that will be cleared
    const studentsSelect = document.getElementById('editThesisStudents');
    const coachSelect = document.getElementById('editThesisCoach');
    const expertSelect = document.getElementById('editThesisExpert');
    
    const hasSelections = studentsSelect.value || coachSelect.value || expertSelect.value;
    
    // Clear current selections since they may not be valid for the new department
    studentsSelect.value = '';
    coachSelect.value = '';
    expertSelect.value = '';
    
    if (hasSelections) {
        // Show a subtle notification that assignments were cleared
        const notification = document.createElement('div');
        notification.className = 'alert alert-info alert-dismissible fade show mt-2';
        notification.innerHTML = `
            <i class="bi bi-info-circle"></i> Role assignments cleared due to department change. Please reassign users from the new department.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        this.parentElement.appendChild(notification);
        
        // Auto-remove notification after 5 seconds
        setTimeout(() => {
            if (notification.parentElement) {
                notification.remove();
            }
        }, 5000);
    }
    
    if (departmentId) {
        loadUserOptions(departmentId);
    } else {
        loadUserOptions(); // Load all users if no department selected
    }
});

// Auto-populate email field when username changes
document.getElementById('userUsername').addEventListener('blur', function() {
    const usernameField = this;
    const emailField = document.getElementById('userEmail');
    
    // Only auto-populate if email field is empty and username is not empty
    if (usernameField.value.trim() !== '' && emailField.value.trim() === '') {
        emailField.value = usernameField.value.trim() + '@hftm.ch';
    }
});

// State change functionality
function changeThesisState(thesisId) {
    fetch(`/api/theses/${thesisId}/state-options`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                document.getElementById('stateThesisId').value = thesisId;
                document.getElementById('currentState').value = data.currentState;
                
                const newStateSelect = document.getElementById('newState');
                newStateSelect.innerHTML = '<option value="">Select new state...</option>';
                
                data.availableStates.forEach(state => {
                    const option = document.createElement('option');
                    option.value = state.value;
                    option.textContent = state.label;
                    newStateSelect.appendChild(option);
                });
                
                new bootstrap.Modal(document.getElementById('changeStateModal')).show();
            } else {
                alert('Error loading state options: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error loading state options:', error);
            alert('Error loading state options');
        });
}

document.getElementById('changeStateForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const thesisId = formData.get('thesisId');
    const newState = formData.get('newState');
    
    fetch(`/api/theses/${thesisId}/state`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ newState })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('changeStateModal')).hide();
            location.reload();
        } else {
            alert('Error changing state: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error changing state:', error);
        alert('Error changing state');
    });
});

