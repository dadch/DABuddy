<script>
function roleLabel(role) {
    const labels = {
        student: 'Student',
        coach: 'Dozent/in',
        expert: 'ExpertIn',
        admin: 'Administrator',
        department_lead: 'FachbereichsleiterIn',
        field_project_coach: 'Dozent Transferprojekt'
    };
    return labels[role] || role;
}

function openAddThesisModal() {
    document.getElementById('thesisDepartment').value = '';
    loadUserOptions();
    new bootstrap.Modal(document.getElementById('addThesisModal')).show();
}

function openUserManagementModal() {
    loadDepartmentUsers();
    loadDepartmentLeadOptions();
    new bootstrap.Modal(document.getElementById('userManagementModal')).show();
}

function openAddUserModal() {
    loadDepartmentLeadOptions();
    new bootstrap.Modal(document.getElementById('addUserModal')).show();
}

function editThesis(id) {
    fetch(`/api/theses/${id}`)
        .then(response => response.json())
        .then(thesis => {
            document.getElementById('editThesisId').value = thesis.id;
            document.getElementById('editThesisTitle').value = thesis.title;
            document.getElementById('editThesisDepartment').value = thesis.department_id;
            document.getElementById('editThesisSponsor').value = thesis.sponsor || '';
            document.getElementById('editThesisLanguage').value = thesis.language || 'de';
            document.getElementById('editThesisIsConfidential').checked = !!thesis.is_confidential;

            return loadUserOptions(thesis.department_id).then(() => {
                const studentsSelect = document.getElementById('editThesisStudents');
                Array.from(studentsSelect.options).forEach(option => {
                    option.selected = thesis.students.some(student => student.id == option.value);
                });

                const coachSelect = document.getElementById('editThesisCoach');
                if (thesis.coaches.length > 0) {
                    const coachOption = Array.from(coachSelect.options).find(option =>
                        option.value == thesis.coaches[0].id
                    );
                    if (coachOption) {
                        coachSelect.value = thesis.coaches[0].id;
                    }
                }

                const expertSelect = document.getElementById('editThesisExpert');
                if (thesis.experts.length > 0) {
                    const expertOption = Array.from(expertSelect.options).find(option =>
                        option.value == thesis.experts[0].id
                    );
                    if (expertOption) {
                        expertSelect.value = thesis.experts[0].id;
                    }
                }

                const fpcSelect = document.getElementById('editThesisFieldProjectCoach');
                if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) {
                    const fpcOption = Array.from(fpcSelect.options).find(option =>
                        option.value == thesis.fieldProjectCoaches[0].id
                    );
                    if (fpcOption) {
                        fpcSelect.value = thesis.fieldProjectCoaches[0].id;
                    }
                }

                new bootstrap.Modal(document.getElementById('editThesisModal')).show();
            });
        })
        .catch(error => {
            console.error('Fehler beim Laden der Diplomarbeit:', error);
            alert('Fehler beim Laden der Diplomarbeit-Daten');
        });
}

function deleteThesis(id) {
    if (confirm('Möchten Sie diese Diplomarbeit wirklich löschen?')) {
        fetch(`/api/theses/${id}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Fehler beim Löschen der Diplomarbeit');
            }
        })
        .catch(error => {
            console.error('Fehler beim Löschen der Diplomarbeit:', error);
            alert('Fehler beim Löschen der Diplomarbeit');
        });
    }
}

function loadUserOptions(departmentId = null) {
    return fetch('/api/users')
        .then(response => response.json())
        .then(users => {
            let filteredUsers = users;
            if (departmentId) {
                filteredUsers = users.filter(user =>
                    user.departments && user.departments.some(dept => dept.id == departmentId)
                );
            }

            const students = filteredUsers.filter(user => user.role === 'student');
            const coaches = filteredUsers.filter(user => user.role === 'coach');
            const experts = filteredUsers.filter(user => user.role === 'expert');
            const fieldProjectCoaches = filteredUsers.filter(user => user.role === 'field_project_coach');

            ['thesisStudents', 'editThesisStudents'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">Studenten auswählen...</option>';
                    students.forEach(student => {
                        const option = document.createElement('option');
                        option.value = student.id;
                        option.textContent = `${student.name}, ${student.firstname}`;
                        select.appendChild(option);
                    });
                }
            });

            ['thesisCoach', 'editThesisCoach'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">Dozent/in auswählen...</option>';
                    coaches.forEach(coach => {
                        const option = document.createElement('option');
                        option.value = coach.id;
                        option.textContent = `${coach.name}, ${coach.firstname}`;
                        select.appendChild(option);
                    });
                }
            });

            ['thesisExpert', 'editThesisExpert'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">ExpertIn auswählen...</option>';
                    experts.forEach(expert => {
                        const option = document.createElement('option');
                        option.value = expert.id;
                        option.textContent = `${expert.name}, ${expert.firstname}`;
                        select.appendChild(option);
                    });
                }
            });

            ['thesisFieldProjectCoach', 'editThesisFieldProjectCoach'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '<option value="">Field Project Dozent/in auswählen...</option>';
                    fieldProjectCoaches.forEach(fpc => {
                        const option = document.createElement('option');
                        option.value = fpc.id;
                        option.textContent = `${fpc.name}, ${fpc.firstname}`;
                        select.appendChild(option);
                    });
                }
            });
        })
        .catch(error => {
            console.error('Fehler beim Laden der Benutzeroptionen:', error);
        });
}

function loadDepartmentUsers() {
    fetch('/api/department-lead/users')
        .then(response => response.json())
        .then(users => {
            const usersList = document.getElementById('usersList');
            usersList.innerHTML = `
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Benutzername</th>
                                <th>Name</th>
                                <th>E-Mail</th>
                                <th>Rolle</th>
                                <th>Fachbereiche</th>
                                <th>Aktionen</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${users.map(user => `
                                <tr>
                                    <td>${user.username}</td>
                                    <td>${user.name}, ${user.firstname}</td>
                                    <td>${user.email}</td>
                                    <td><span class="badge bg-secondary">${roleLabel(user.role)}</span></td>
                                    <td>
                                        ${user.departments && user.departments.length > 0
                                            ? user.departments.map(dept => `<span class="badge bg-info me-1">${dept.name}</span>`).join('')
                                            : '<span class="text-muted">Keine Fachbereiche</span>'}
                                    </td>
                                    <td>
                                        <button class="btn btn-outline-primary btn-sm me-1" onclick="editUser(${user.id})">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" onclick="deleteUser(${user.id})">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
            `;
        })
        .catch(error => {
            console.error('Fehler beim Laden der Benutzer:', error);
            document.getElementById('usersList').innerHTML = '<div class="alert alert-danger">Fehler beim Laden der Benutzer</div>';
        });
}

function loadDepartmentLeadOptions() {
    fetch('/api/department-lead/departments')
        .then(response => response.json())
        .then(departments => {
            ['userDepartments', 'editUserDepartments'].forEach(selectId => {
                const select = document.getElementById(selectId);
                if (select) {
                    select.innerHTML = '';
                    departments.forEach(dept => {
                        const option = document.createElement('option');
                        option.value = dept.id;
                        option.textContent = dept.name;
                        select.appendChild(option);
                    });
                }
            });
        })
        .catch(error => {
            console.error('Fehler beim Laden der Fachbereichsoptionen:', error);
        });
}

function editUser(userId) {
    fetch(`/api/department-lead/users`)
        .then(response => response.json())
        .then(users => {
            const user = users.find(u => u.id === userId);
            if (user) {
                document.getElementById('editUserId').value = user.id;
                document.getElementById('editUserUsername').value = user.username;
                document.getElementById('editUserFirstname').value = user.firstname;
                document.getElementById('editUserName').value = user.name;
                document.getElementById('editUserEmail').value = user.email;
                document.getElementById('editUserPhone').value = user.phone || '';
                document.getElementById('editUserRole').value = user.role;
                document.getElementById('editUserPassword').value = '';

                const additionalSelect = document.getElementById('editUserAdditionalRoles');
                const additional = new Set(user.additional_roles || []);
                Array.from(additionalSelect.options).forEach(option => {
                    option.selected = additional.has(option.value);
                });

                const departmentSelect = document.getElementById('editUserDepartments');
                if (departmentSelect && user.departments) {
                    Array.from(departmentSelect.options).forEach(option => {
                        option.selected = user.departments.some(dept => dept.id == option.value);
                    });
                }

                new bootstrap.Modal(document.getElementById('editUserModal')).show();
            }
        })
        .catch(error => {
            console.error('Fehler beim Laden des Benutzers:', error);
            alert('Fehler beim Laden der Benutzerdaten');
        });
}

function deleteUser(id) {
    if (confirm('Möchten Sie diesen Benutzer wirklich löschen?')) {
        fetch(`/api/department-lead/users/${id}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                loadDepartmentUsers();
            } else {
                alert('Fehler beim Löschen des Benutzers');
            }
        })
        .catch(error => {
            console.error('Fehler beim Löschen des Benutzers:', error);
            alert('Fehler beim Löschen des Benutzers');
        });
    }
}

document.getElementById('addThesisForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    const studentsSelect = document.getElementById('thesisStudents');
    const selectedStudents = Array.from(studentsSelect.selectedOptions).map(option => option.value);

    const coachSelect = document.getElementById('thesisCoach');
    const selectedCoach = coachSelect.value;

    const expertSelect = document.getElementById('thesisExpert');
    const selectedExpert = expertSelect.value;

    const fpcSelect = document.getElementById('thesisFieldProjectCoach');

    data.students = selectedStudents;
    data.coach = selectedCoach;
    data.expert = selectedExpert;
    data.field_project_coach = fpcSelect.value;
    data.is_confidential = document.getElementById('thesisIsConfidential').checked;

    fetch('/api/theses', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('addThesisModal')).hide();
            location.reload();
        } else {
            alert('Fehler beim Hinzufügen der Diplomarbeit: ' + (data.message || 'Unbekannter Fehler'));
        }
    })
    .catch(error => {
        console.error('Fehler beim Hinzufügen der Diplomarbeit:', error);
        alert('Fehler beim Hinzufügen der Diplomarbeit');
    });
});

document.getElementById('editThesisForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    const studentsSelect = document.getElementById('editThesisStudents');
    const selectedStudents = Array.from(studentsSelect.selectedOptions).map(option => option.value);

    const coachSelect = document.getElementById('editThesisCoach');
    const selectedCoach = coachSelect.value;

    const expertSelect = document.getElementById('editThesisExpert');
    const selectedExpert = expertSelect.value;

    const fpcSelect = document.getElementById('editThesisFieldProjectCoach');

    data.students = selectedStudents;
    data.coach = selectedCoach;
    data.expert = selectedExpert;
    data.field_project_coach = fpcSelect.value;
    data.is_confidential = document.getElementById('editThesisIsConfidential').checked;

    const thesisId = data.id;

    fetch(`/api/theses/${thesisId}`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('editThesisModal')).hide();
            location.reload();
        } else {
            alert('Fehler beim Aktualisieren der Diplomarbeit: ' + (data.message || 'Unbekannter Fehler'));
        }
    })
    .catch(error => {
        console.error('Fehler beim Aktualisieren der Diplomarbeit:', error);
        alert('Fehler beim Aktualisieren der Diplomarbeit');
    });
});

document.getElementById('addUserForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);

    const departmentSelect = document.getElementById('userDepartments');
    const selectedDepartments = Array.from(departmentSelect.selectedOptions).map(option => option.value);
    data.departments = selectedDepartments;
    data.additional_roles = Array.from(document.getElementById('userAdditionalRoles').selectedOptions).map(o => o.value);

    fetch('/api/department-lead/users', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('addUserModal')).hide();
            loadDepartmentUsers();
            this.reset();
        } else {
            alert('Fehler beim Hinzufügen des Benutzers: ' + (data.message || 'Unbekannter Fehler'));
        }
    })
    .catch(error => {
        console.error('Fehler beim Hinzufügen des Benutzers:', error);
        alert('Fehler beim Hinzufügen des Benutzers');
    });
});

document.getElementById('editUserForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const formData = new FormData(this);
    const data = Object.fromEntries(formData);
    const userId = data.id;

    const departmentSelect = document.getElementById('editUserDepartments');
    const selectedDepartments = Array.from(departmentSelect.selectedOptions).map(option => option.value);
    data.departments = selectedDepartments;
    data.additional_roles = Array.from(document.getElementById('editUserAdditionalRoles').selectedOptions).map(o => o.value);

    fetch(`/api/department-lead/users/${userId}`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
            loadDepartmentUsers();
            this.reset();
        } else {
            alert('Fehler beim Aktualisieren des Benutzers: ' + (data.message || 'Unbekannter Fehler'));
        }
    })
    .catch(error => {
        console.error('Fehler beim Aktualisieren des Benutzers:', error);
        alert('Fehler beim Aktualisieren des Benutzers');
    });
});

document.getElementById('thesisDepartment').addEventListener('change', function() {
    const departmentId = this.value;
    if (departmentId) {
        loadUserOptions(departmentId);
    } else {
        loadUserOptions();
    }
});

document.getElementById('editThesisDepartment').addEventListener('change', function() {
    const departmentId = this.value;

    const studentsSelect = document.getElementById('editThesisStudents');
    const coachSelect = document.getElementById('editThesisCoach');
    const expertSelect = document.getElementById('editThesisExpert');
    const fpcSelect = document.getElementById('editThesisFieldProjectCoach');

    const hasSelections = studentsSelect.value || coachSelect.value || expertSelect.value || fpcSelect.value;

    studentsSelect.value = '';
    coachSelect.value = '';
    expertSelect.value = '';
    fpcSelect.value = '';

    if (hasSelections) {
        const notification = document.createElement('div');
        notification.className = 'alert alert-info alert-dismissible fade show mt-2';
        notification.innerHTML = `
            <i class="bi bi-info-circle"></i> Rollenzuweisungen wurden aufgrund des Fachbereichswechsels zurückgesetzt. Bitte Benutzer aus dem neuen Fachbereich neu zuweisen.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        this.parentElement.appendChild(notification);

        setTimeout(() => {
            if (notification.parentElement) {
                notification.remove();
            }
        }, 5000);
    }

    if (departmentId) {
        loadUserOptions(departmentId);
    } else {
        loadUserOptions();
    }
});

document.getElementById('userUsername').addEventListener('blur', function() {
    const usernameField = this;
    const emailField = document.getElementById('userEmail');

    if (usernameField.value.trim() !== '' && emailField.value.trim() === '') {
        emailField.value = usernameField.value.trim() + '@hftm.ch';
    }
});

</script>

