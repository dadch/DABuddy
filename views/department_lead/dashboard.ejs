<%- include('../partials/header', { title: 'Department Lead Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Department Management</h1>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Academic Year: <%= selectedYear %>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-mortarboard"></i> Department Theses
                </h5>
                <h3 class="text-primary"><%= theses.length %></h3>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-people"></i> Actions
                </h5>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-success" onclick="openAddThesisModal()">
                        <i class="bi bi-plus"></i> Add Thesis
                    </button>
                    <button type="button" class="btn btn-info" onclick="openUserManagementModal()">
                        <i class="bi bi-person-gear"></i> Manage Users
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (departments.length > 1) { %>
<div class="row mb-3">
    <div class="col-md-4">
        <form method="GET" action="/dashboard" class="d-flex">
            <select name="department" class="form-select me-2" onchange="this.form.submit()">
                <option value="">All My Departments</option>
                <% departments.forEach(function(dept) { %>
                    <option value="<%= dept.id %>" <%= selectedDepartment == dept.id ? 'selected' : '' %>>
                        <%= dept.name %>
                    </option>
                <% }); %>
            </select>
        </form>
    </div>
</div>
<% } %>

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5>Department Theses</h5>
            </div>
            <div class="card-body">
                <% if (theses.length === 0) { %>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> No theses found for your department(s).
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-striped">
                            <thead>
                                <tr>
                                    <th>Thesis Title</th>
                                    <th>Department</th>
                                    <th>Students</th>
                                    <th>Coaches</th>
                                    <th>Experts</th>
                                    <th>Sponsor</th>
                                    <th>State</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% theses.forEach(function(thesis) { %>
                                    <tr>
                                        <td>
                                            <strong><%= thesis.title %></strong>
                                        </td>
                                        <td><%= thesis.department.name %></td>
                                        <td>
                                            <% if (thesis.students.length > 0) { %>
                                                <% thesis.students.forEach(function(student, index) { %>
                                                    <span class="badge bg-primary me-1"><%= student.firstname %> <%= student.name %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">No students assigned</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (thesis.coaches.length > 0) { %>
                                                <% thesis.coaches.forEach(function(coach, index) { %>
                                                    <span class="badge bg-success me-1"><%= coach.firstname %> <%= coach.name %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">No coaches assigned</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <% if (thesis.experts.length > 0) { %>
                                                <% thesis.experts.forEach(function(expert, index) { %>
                                                    <span class="badge bg-info me-1"><%= expert.firstname %> <%= expert.name %></span>
                                                <% }); %>
                                            <% } else { %>
                                                <span class="text-muted">No experts assigned</span>
                                            <% } %>
                                        </td>
                                        <td><%= thesis.sponsor || '-' %></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="badge bg-<%= getStateColor(thesis.state) %> me-2">
                                                    <%= thesis.state %>
                                                </span>
                                                <button class="btn btn-outline-info btn-sm" onclick="changeThesisState(<%= thesis.id %>)" title="Change State">
                                                    <i class="bi bi-arrow-repeat"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="editThesis(<%= thesis.id %>)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button type="button" class="btn btn-outline-danger btn-sm" onclick="deleteThesis(<%= thesis.id %>)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Add Thesis Modal -->
<div class="modal fade" id="addThesisModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Thesis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addThesisForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="thesisTitle" class="form-label">Title</label>
                        <input type="text" class="form-control" id="thesisTitle" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label for="thesisDepartment" class="form-label">Department</label>
                        <select class="form-select" id="thesisDepartment" name="department_id" required>
                            <option value="">Select Department</option>
                            <% departments.forEach(function(dept) { %>
                                <option value="<%= dept.id %>"><%= dept.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisSponsor" class="form-label">Sponsor (Optional)</label>
                        <input type="text" class="form-control" id="thesisSponsor" name="sponsor">
                    </div>
                    <div class="mb-3">
                        <label for="thesisStudents" class="form-label">Students (1-2 maximum)</label>
                        <select class="form-select" id="thesisStudents" name="students" multiple size="4">
                            <option value="">Select students...</option>
                        </select>
                        <div class="form-text">Hold Ctrl/Cmd to select multiple students (maximum 2)</div>
                    </div>
                    <div class="mb-3">
                        <label for="thesisCoach" class="form-label">Coach</label>
                        <select class="form-select" id="thesisCoach" name="coach">
                            <option value="">Select coach...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="thesisExpert" class="form-label">Expert</label>
                        <select class="form-select" id="thesisExpert" name="expert">
                            <option value="">Select expert...</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Thesis</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Thesis Modal -->
<div class="modal fade" id="editThesisModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Thesis</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editThesisForm">
                <div class="modal-body">
                    <input type="hidden" id="editThesisId" name="id">
                    <div class="mb-3">
                        <label for="editThesisTitle" class="form-label">Title</label>
                        <input type="text" class="form-control" id="editThesisTitle" name="title" required>
                    </div>
                    <div class="mb-3">
                        <label for="editThesisDepartment" class="form-label">Department</label>
                        <select class="form-select" id="editThesisDepartment" name="department_id" required>
                            <option value="">Select Department</option>
                            <% departments.forEach(function(dept) { %>
                                <option value="<%= dept.id %>"><%= dept.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="editThesisSponsor" class="form-label">Sponsor (Optional)</label>
                        <input type="text" class="form-control" id="editThesisSponsor" name="sponsor">
                    </div>
                    <div class="mb-3">
                        <label for="editThesisStudents" class="form-label">Students (1-2 maximum)</label>
                        <select class="form-select" id="editThesisStudents" name="students" multiple size="4">
                            <option value="">Select students...</option>
                        </select>
                        <div class="form-text">Hold Ctrl/Cmd to select multiple students (maximum 2)</div>
                    </div>
                    <div class="mb-3">
                        <label for="editThesisCoach" class="form-label">Coach</label>
                        <select class="form-select" id="editThesisCoach" name="coach">
                            <option value="">Select coach...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="editThesisExpert" class="form-label">Expert</label>
                        <select class="form-select" id="editThesisExpert" name="expert">
                            <option value="">Select expert...</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Thesis</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- User Management Modal -->
<div class="modal fade" id="userManagementModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">User Management</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <button type="button" class="btn btn-success" onclick="openAddUserModal()">
                            <i class="bi bi-person-plus"></i> Add User
                        </button>
                    </div>
                </div>
                <div id="usersList">
                    <!-- Users will be loaded here -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addUserForm">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="userUsername" class="form-label">Username</label>
                        <input type="text" class="form-control" id="userUsername" name="username" required>
                    </div>
                    <div class="mb-3">
                        <label for="userPassword" class="form-label">Password</label>
                        <input type="password" class="form-control" id="userPassword" name="password" required>
                    </div>
                    <div class="mb-3">
                        <label for="userFirstname" class="form-label">First Name</label>
                        <input type="text" class="form-control" id="userFirstname" name="firstname" required>
                    </div>
                    <div class="mb-3">
                        <label for="userName" class="form-label">Last Name</label>
                        <input type="text" class="form-control" id="userName" name="name" required>
                    </div>
                    <div class="mb-3">
                        <label for="userEmail" class="form-label">Email</label>
                        <input type="email" class="form-control" id="userEmail" name="email" required>
                    </div>
                    <div class="mb-3">
                        <label for="userRole" class="form-label">Role</label>
                        <select class="form-select" id="userRole" name="role" required>
                            <option value="">Select Role</option>
                            <option value="student">Student</option>
                            <option value="coach">Coach</option>
                            <option value="expert">Expert</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="userDepartments" class="form-label">Departments</label>
                        <select class="form-select" id="userDepartments" name="departments" multiple>
                            <!-- Options will be populated by JavaScript -->
                        </select>
                        <div class="form-text">Hold Ctrl/Cmd to select multiple departments</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add User</button>
                </div>
            </form>
        </div>
    </div>
</div>

