<%- include('../partials/header', { title: 'ExpertIn-Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Diplomarbeiten zur Begutachtung</h1>
    <div class="text-muted">
        <i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear %>
    </div>
</div>

<% if (theses.length === 0) { %>
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        Im ausgewählten Diplomjahr sind Ihnen keine Diplomarbeiten zur Begutachtung zugewiesen.
    </div>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Titel der Diplomarbeit</th>
                    <th>Fachbereich</th>
                    <th>Studenten</th>
                    <th>Coach</th>
                    <th>Field Project Coach</th>
                    <th>Auftraggeber</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                <% theses.forEach(function(thesis) { %>
                    <tr>
                        <td><strong><%= thesis.title %></strong></td>
                        <td><%= thesis.department.name %></td>
                        <td>
                            <% thesis.students.forEach(function(s, i) { %>
                                <%= s.firstname %> <%= s.name %><% if (i < thesis.students.length - 1) { %>, <% } %>
                            <% }); %>
                        </td>
                        <td>
                            <% thesis.coaches.forEach(function(c, i) { %>
                                <%= c.firstname %> <%= c.name %><% if (i < thesis.coaches.length - 1) { %>, <% } %>
                            <% }); %>
                        </td>
                        <td>
                            <% if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) { %>
                                <% thesis.fieldProjectCoaches.forEach(function(f, i) { %>
                                    <%= f.firstname %> <%= f.name %><% if (i < thesis.fieldProjectCoaches.length - 1) { %>, <% } %>
                                <% }); %>
                            <% } else { %>-<% } %>
                        </td>
                        <td><%= thesis.sponsor || '-' %></td>
                        <td>
                            <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                                <i class="bi bi-eye"></i> Details & Meilensteine
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>

<%- include('../partials/footer') %>
