<%- include('../partials/header', { title: 'ExpertIn-Dashboard - DABuddy', user: user }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Diplomarbeiten zur Begutachtung</h1>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted"><i class="bi bi-calendar"></i> Diplomjahr: <%= selectedYear %></span>
        <%- include('../partials/role-switcher', { availableRoles: availableRoles, currentRole: currentRole }) %>
    </div>
</div>

<% if (theses.length === 0) { %>
    <div class="alert alert-info" role="alert">
        <i class="bi bi-info-circle"></i>
        Im ausgewählten Diplomjahr sind Ihnen keine Diplomarbeiten zur Begutachtung zugewiesen.
    </div>
<% } else { %>
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Titel der Diplomarbeit</th>
                    <th>Fachbereich</th>
                    <th>Studenten</th>
                    <th>Dozent/in</th>
                    <th>Field Project Coach</th>
                    <th>Auftraggeber</th>
                    <th>Aktionen</th>
                </tr>
            </thead>
            <tbody>
                <% theses.forEach(function(thesis) { %>
                    <tr>
                        <td><strong><%= thesis.title %></strong></td>
                        <td><%= thesis.department.name %></td>
                        <td>
                            <% thesis.students.forEach(function(s, i) { %>
                                <%= s.name %>, <%= s.firstname %><% if (i < thesis.students.length - 1) { %>, <% } %>
                            <% }); %>
                        </td>
                        <td>
                            <% thesis.coaches.forEach(function(c, i) { %>
                                <%= c.name %>, <%= c.firstname %><% if (i < thesis.coaches.length - 1) { %>, <% } %>
                            <% }); %>
                        </td>
                        <td>
                            <% if (thesis.fieldProjectCoaches && thesis.fieldProjectCoaches.length > 0) { %>
                                <% thesis.fieldProjectCoaches.forEach(function(f, i) { %>
                                    <%= f.name %>, <%= f.firstname %><% if (i < thesis.fieldProjectCoaches.length - 1) { %>, <% } %>
                                <% }); %>
                            <% } else { %>-<% } %>
                        </td>
                        <td><%= thesis.sponsor || '-' %></td>
                        <td>
                            <a href="/dashboard/thesis/<%= thesis.id %>" class="btn btn-primary btn-sm">
                                <i class="bi bi-eye"></i> Details & Meilensteine
                            </a>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
<% } %>

<%- include('../partials/footer') %>
