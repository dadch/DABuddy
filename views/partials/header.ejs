<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'de' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'ThesisBuddy - Diplomarbeit-Verwaltungssystem' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
</head>
<body>
<div class="app-mobile-bar">
    <div class="brand-row">
        <span class="brand-logo">D</span>
        <span class="brand-text">ThesisBuddy</span>
    </div>
    <button type="button" class="menu-toggle" onclick="document.querySelector('.app-sidebar').classList.add('is-open'); document.querySelector('.app-sidebar-backdrop').classList.add('show');" aria-label="Menü öffnen">
        <i class="bi bi-list"></i>
    </button>
</div>
<div class="app-sidebar-backdrop" onclick="document.querySelector('.app-sidebar').classList.remove('is-open'); this.classList.remove('show');"></div>
<div class="app-shell">
    <%- include('sidebar', { user: typeof user !== 'undefined' ? user : null, activeNav: typeof activeNav !== 'undefined' ? activeNav : '' }) %>

    <main class="app-main">
        <% if (typeof messages !== 'undefined' && messages) { %>
            <% if (messages.success && messages.success.length > 0) { %>
                <% messages.success.forEach(function(message) { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= message %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% }); %>
            <% } %>
            <% if (messages.error && messages.error.length > 0) { %>
                <% messages.error.forEach(function(message) { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= message %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% }); %>
            <% } %>
        <% } %>
