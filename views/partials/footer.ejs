    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/easymde/dist/easymde.min.js"></script>
<script>
    // Markdown-Helfer. Einzelne Zeilenumbrüche und Leerzeilen werden berücksichtigt
    // (breaks + gfm). Fällt auf escapeten Text zurück, falls marked fehlt.
    var MD_OPTS = { breaks: true, gfm: true };
    function escapeTextFallback(s) {
        return s.replace(/[&<>"]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
    }
    function renderMarkdownInline(text) {
        const s = (text === undefined || text === null) ? '' : String(text);
        try {
            if (window.marked && typeof marked.parseInline === 'function') return marked.parseInline(s, MD_OPTS);
        } catch (e) { /* fall through */ }
        return escapeTextFallback(s);
    }
    function renderMarkdownBlock(text) {
        const s = (text === undefined || text === null) ? '' : String(text);
        try {
            if (window.marked && typeof marked.parse === 'function') return marked.parse(s, MD_OPTS);
        } catch (e) { /* fall through */ }
        return escapeTextFallback(s).replace(/\n/g, '<br>');
    }
</script>
<script src="/js/app.js"></script>
</body>
