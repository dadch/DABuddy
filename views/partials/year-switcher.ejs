<!-- Diplomjahr-Switcher für Admin/FachbereichsleiterIn. Erwartet:
       - availableYears: Array von { id, year, label_de, label_fr }
       - selectedYearId:   id des aktuell gewählten Jahres
     Die Anzeige nutzt die zweisprachige Bezeichnung (Fallback: Jahreszahl). -->
<% if ((availableYears || []).length > 1) { %>
    <label class="pill-btn" for="yearSwitcher">
        <i class="bi bi-calendar3"></i>
        <span><%= t('dashboard.year') %></span>
        <select class="form-select" id="yearSwitcher" onchange="switchDiplomjahr(this.value)" aria-label="<%= t('dashboard.year') %>"
                style="border:0; background:transparent; padding:0; margin-left:4px; height:auto; width:auto; font:inherit; color:inherit; outline:none; box-shadow:none;">
            <% availableYears.forEach(function(y) { %>
                <option value="<%= y.id %>" <%= y.id === selectedYearId ? 'selected' : '' %>><%= yearLabel(y) %></option>
            <% }); %>
        </select>
    </label>
<% } else if ((availableYears || []).length === 1) { %>
    <span class="pill-btn">
        <i class="bi bi-calendar3"></i>
        <%= t('dashboard.year') %> <%= yearLabel(availableYears[0]) %>
    </span>
<% } %>
<script>
function switchDiplomjahr(yearId) {
    fetch('/api/year/switch', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ yearId: parseInt(yearId, 10) })
    })
    .then(r => r.json())
    .then(d => {
        if (d.success) location.href = '/dashboard';
        else alert('Fehler: ' + (d.message || 'Unbekannt'));
    })
    .catch(err => { console.error(err); alert('Fehler beim Wechseln'); });
}
</script>
