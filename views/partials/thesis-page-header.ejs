<!-- Page-Header der DA-Detailseite. Erwartet: thesis, user.
     Optional: subtitle override via locals.subtitle.
     Optional: hasTransferProject (boolean) — wenn true, wird der Button
     "Transferprojekt" eingeblendet (für Studierende, Dozent/in, Dozent
     Transferprojekt, FBL und Admin). -->
<%
const subtitleParts = [];
if (thesis.department && thesis.department.name) subtitleParts.push(thesis.department.name);
if (thesis.sponsor) subtitleParts.push(thesis.sponsor);
const computedSubtitle = subtitleParts.join(' · ');
const _hasTransfer = (typeof hasTransferProject !== 'undefined') && !!hasTransferProject;
const _transferRoles = ['student', 'coach', 'department_lead', 'admin', 'field_project_coach'];
const _showTransferBtn = _hasTransfer && user && _transferRoles.includes(user.role);
%>
<div class="page-breadcrumb mb-2">
    <a href="/dashboard">Dashboard</a>
    <span class="sep"></span>
    <span>Diplomarbeit-Details</span>
</div>
<div class="page-header">
    <div>
        <h1 class="page-title"><%= thesis.title %></h1>
        <% if (computedSubtitle) { %>
            <div class="page-subtitle"><%= computedSubtitle %></div>
        <% } %>
    </div>
    <div class="page-actions">
        <a href="/dashboard/thesis/<%= thesis.id %>/chat" class="pill-btn">
            <i class="bi bi-chat-dots"></i> Chat
        </a>
        <a href="/dashboard/document-templates?from=<%= thesis.id %>" class="pill-btn" title="Dokumentvorlagen und Downloads">
            <i class="bi bi-folder2-open"></i> Vorlagen
        </a>
        <% if (_showTransferBtn) { %>
            <a href="/api/theses/<%= thesis.id %>/transfer-project.pdf"
               target="_blank"
               class="pill-btn"
               title="Zusammenzug aller Bewertungen mit Transferprojekt-Kennzeichnung als PDF">
                <i class="bi bi-arrow-left-right"></i> Transferprojekt
            </a>
        <% } %>
        <span class="pill-btn">
            <i class="bi bi-calendar3"></i> Diplomjahr <%= thesis.year.year %>
        </span>
    </div>
</div>
