<%- include('partials/header', { title: t('profile.title') + ' - ThesisBuddy', user: user }) %>

<div class="page-breadcrumb mb-2">
    <a href="/dashboard"><%= t('nav.dashboard') %></a>
    <span class="sep"></span>
    <span><%= t('profile.title') %></span>
</div>
<div class="page-header">
    <div>
        <h1 class="page-title"><%= t('profile.title') %></h1>
        <div class="page-subtitle"><%= t('profile.subtitle') %></div>
    </div>
</div>

<% if (messages && messages.success && messages.success.length) { %>
    <% messages.success.forEach(function(m) { %>
        <div class="alert alert-success"><%= m %></div>
    <% }); %>
<% } %>
<% if (messages && messages.error && messages.error.length) { %>
    <% messages.error.forEach(function(m) { %>
        <div class="alert alert-danger"><%= m %></div>
    <% }); %>
<% } %>

<div class="card">
    <div class="card-body">
        <form method="POST" action="/dashboard/profile">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label small text-muted"><%= t('common.view') %></label>
                    <div><strong><%= profile.firstname %> <%= profile.name %></strong></div>
                    <div class="text-muted small"><%= profile.email %></div>
                </div>
            </div>

            <hr class="my-4">

            <h5 class="mb-2"><%= t('profile.languageSection') %></h5>
            <p class="text-muted small mb-3"><%= t('profile.languageHelp') %></p>
            <div class="mb-4" style="max-width: 320px;">
                <label for="language" class="form-label"><%= t('profile.languageLabel') %></label>
                <select id="language" name="language" class="form-select">
                    <% supportedLanguages.forEach(function(code) { %>
                        <option value="<%= code %>" <%= profile.language === code ? 'selected' : '' %>>
                            <%= t('profile.languages.' + code) %>
                        </option>
                    <% }); %>
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> <%= t('common.save') %>
                </button>
                <a href="/dashboard" class="btn btn-outline-secondary">
                    <%= t('common.cancel') %>
                </a>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer') %>
