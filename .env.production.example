# ThesisBuddy — Produktions-Konfiguration
# Kopieren nach .env und alle <...>-Platzhalter ersetzen. Die Datei .env wird
# NIE eingecheckt und NIE ins Docker-Image kopiert (.gitignore/.dockerignore).

NODE_ENV=production
PORT=3000

# ---------- Datenbank ----------
# DB_HOST/DB_PORT werden im docker-compose.yml fix auf den db-Service gesetzt.
DB_HOST=db
DB_PORT=5432
DB_NAME=dabuddy
DB_USER=dabuddy
# Starkes Passwort setzen, z.B.:  openssl rand -hex 24
DB_PASSWORD=<starkes-db-passwort>

# ---------- Sessions ----------
# Zufälliger Wert, z.B.:  openssl rand -hex 32
SESSION_SECRET=<zufaelliger-session-secret>

# ---------- Mail (SMTP) ----------
MAIL_HOST=<smtp.hftm.ch>
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=<smtp-benutzer>
MAIL_PASS=<smtp-passwort>
MAIL_FROM=ThesisBuddy <thesisbuddy@hftm.ch>
# Produktion: LEER lassen! Wenn gesetzt, werden ALLE Mails an diese Adresse
# umgeleitet (Test-Override).
MAIL_OVERRIDE_TO=
# Täglicher Erinnerungs-/Benachrichtigungs-Job (Cron-Syntax), 07:00 Uhr:
MAIL_CRON=0 7 * * *

# ---------- M365-Login (Azure AD) ----------
# In der Azure-App-Registrierung muss als Redirect-URI eingetragen sein:
#   https://thesisbuddy.hftm.ch/auth/microsoft/callback
MS_TENANT_ID=<azure-tenant-id>
MS_CLIENT_ID=<azure-client-id>
MS_CLIENT_SECRET=<azure-client-secret>
MS_REDIRECT_URI=https://thesisbuddy.hftm.ch/auth/microsoft/callback

# ---------- LLM (Feedback-Vorschläge) ----------
ANTHROPIC_API_KEY=<anthropic-api-key>
